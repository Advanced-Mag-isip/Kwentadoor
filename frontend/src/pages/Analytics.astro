---
import Layout from "../layouts/Layout.astro";

import AnalyticsFilters from "../components/AnalyticsFilters.astro";
import IncomeVsExpenses from "../Charts/IncomeVsExpenses.astro";
import RunawayChart from "../Charts/RunawayChart.astro";
import ExpensesByCategory from "../Charts/ExpensesByCategory.astro";
import IncomeUtilization from "../Charts/IncomeUtilization.astro";

import cashIcon from "../assets/cash-icon.svg?raw";
import cashUpIcon from "../assets/cash-up-icon.svg?raw";
import cashDownIcon from "../assets/cash-down-arrow.svg?raw";
import percentageUpIcon from "../assets/percentage-note-up.svg?raw";
import percentageDownIcon from "../assets/percentage-note-down.svg?raw";
---

<Layout>
    <div id="analytics-container">
        <div class="analytics-inner">
            <AnalyticsFilters />
            <div id="metrics-container">
            <div class="metrics-row cols-2">
                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">TOTAL INCOMING FUNDS</span>
                        <span class="metric-value" id="metric-incoming-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={cashDownIcon} />
                    </div>
                </div>

                 <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">TOTAL OUTGOING FUNDS</span>
                        <span class="metric-value" id="metric-outgoing-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={cashUpIcon} />
                    </div>
                </div>
            </div>

            <div class="metrics-row cols-3">
                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">AVERAGE INCOMING FUNDS</span>
                        <span class="metric-value" id="metric-avg-incoming-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={percentageDownIcon} />
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">AVERAGE OUTGOING FUNDS</span>
                        <span class="metric-value" id="metric-avg-outgoing-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={percentageUpIcon} />
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">TOTAL PAYROLL COSTS</span>
                        <span class="metric-value" id="metric-payroll-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={cashDownIcon} />
                    </div>
                </div>
            </div>

            <div class="metrics-row cols-3">
                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">TOTAL MISSING RECEIPTS</span>
                        <span class="metric-value" id="metric-missing-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={cashDownIcon} />
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">UNDOCUMENTED EXPENSES %</span>
                        <span class="metric-value" id="metric-undocumented-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={cashDownIcon} />
                    </div>
                </div>

                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">EXPENSE GROWTH</span>
                        <span class="metric-value" id="metric-growth-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={cashIcon} />
                    </div>
                </div>
            </div>

            <div class="metrics-row cols-2">
                <div class="graph-card">
                    <span class="graph-label orange">TOTAL INCOMING VS OUTGOING THIS MONTH</span>
                    <div class="graph-content">
                        <IncomeVsExpenses />
                    </div>
                </div>

                <div class="graph-card">
                    <span class="graph-label blue">FUNDING RUNAWAY PROJECTION</span>
                    <div class="graph-content">
                        <RunawayChart />
                    </div>
                </div>
            </div>

            <div class="metrics-row cols-2">
                <div class="graph-card">
                    <span class="graph-label blue">EXPENSES BY CATEGORY</span>
                    <div class="graph-content">
                        <ExpensesByCategory />
                    </div>
                </div>

                <div class="graph-card">
                    <span class="graph-label orange">INCOME UTILIZATION</span>
                    <div class="graph-content">
                        <IncomeUtilization />
                    </div>
                </div>
            </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    #analytics-container {
        display: flex;
        justify-content: center;
        box-sizing: border-box;
        width: 100%;
    }

    .analytics-inner {
        width: 100%;
        max-width: 1600px;
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-md, 20px);
    }

    #metrics-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .metrics-row {
        display: grid;
        width: 100%;
        gap: 15px;
    }

    .metrics-row.cols-2 {
        grid-template-columns: repeat(2, 1fr);
    }

    .metrics-row.cols-3 {
        grid-template-columns: repeat(3, 1fr);
    }

    
    .metric-card {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        flex: 1; 
        height: 125px; 
        padding: 20px;
        border-radius: 25px;
        box-sizing: border-box;
        background-color: var(--white);
        box-shadow: var(--default-shadow);
        container-type: inline-size;
    }

    .metric-info {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex: 1;
        min-width: 0;
    }

    .metric-label {
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text); 
        color: var(--primary-navyblue);
    }

    .metric-value {
        font-size: clamp(1.1rem, 6cqw, var(--display-headings-text));
        font-family: var(--display-headings-font);
        color: var(--primary-navyblue);
        font-weight: bold;
        margin-top: 10px;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }



    .metric-icon-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 45px;
        height: 45px;
        background-color: var(--light-grey);
        border-radius: 10px;
    }

    .metric-icon-wrapper :global(svg) {
        width: 24px;
        height: auto;
    }


    .graph-card {
        display: flex;
        flex-direction: column;
        flex: 1; 
        height: 320px;
        padding: 20px;
        border-radius: 25px;
        box-sizing: border-box;
        background-color: var(--white);
        box-shadow: var(--default-shadow);
    }

    .graph-content {
        flex: 1;
        min-height: 0;
    }

    .graph-label {
        box-sizing: border-box;
        display: block; 
        padding: 15px;
        margin: -20px -20px 20px -20px; 
        border-radius: 23px 23px 0 0; 
        color: var(--white);
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text); 
    }

    @media (max-width: 1200px) {
        .metrics-row.cols-2,
        .metrics-row.cols-3 {
            grid-template-columns: 1fr;
        }

        .metric-card {
            height: auto;
            min-height: 100px;
        }

        .graph-card {
            height: auto;
            min-height: 280px;
        }
}
</style>

<script>
  import "../scripts/analytics-metrics.js";
</script>