---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Modal from '../components/AddFundsModal.astro';
---

<Layout>
  <div style="padding: 40px;">
    <h1>Dashboard</h1>
    
    <!-- 1. The Trigger Button -->
    <button id="open-expense-modal" class="primary-btn">
      Add New Expense
    </button>

    <!-- 2. The Modal Component -->
    <Modal>
	</Modal>
      
  </div>
</Layout>

<style>
  .primary-btn {
    background-color: var(--primary-orange);
    color: white;
    padding: 10px 20px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-family: var(--headings-font);
    font-weight: bold;
  }
</style>

<!-- Add this at the bottom of src/pages/index.astro -->
<script>
  const openBtn = document.getElementById('open-expense-modal');
  const modalOutside = document.getElementById('addExpenseModal');

  openBtn.addEventListener('click', () => {
    modalOutside.showModal(); 
  });
</script>