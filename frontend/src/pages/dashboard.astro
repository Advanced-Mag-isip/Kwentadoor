---
import Layout from '../layouts/Layout.astro';
import WalletCard from "../components/WalletCard.astro";
import DashboardIncomeVsOutgoing from "../Charts/DashboardIncomeVsOutgoing.astro";
import DashboardExpensesByCategory from "../Charts/DashboardExpensesByCategory.astro";
import DashboardIncomingByWallet from "../Charts/DashboardIncomingByWallet.astro";
import IconBalanceShow from '../assets/funds-visible-icon.svg?raw'; 
import IconCash from '../assets/cash-icon.svg?raw'; 
import IconCashUp from '../assets/cash-up-icon.svg?raw'; 
import IconCashDown from '../assets/cash-down-arrow.svg?raw'; 
import IconTransaction from '../assets/metrics-bidirectional-arrow.svg?raw'; 
import IconAddFunds from '../assets/add-funds-icon.svg?raw'; 
import IconSpendFunds from '../assets/spend-funds-icon.svg?raw';
import IconMoveFunds from '../assets/move-funds-icon.svg?raw';
import IconChevronDown from '../assets/chevron-down.svg?raw';
import IconWallet from '../assets/wallet-icon.svg?raw';
import IconPeso from '../assets/philippine-peso.svg?raw';
import IconAttachment from '../assets/paperclip.svg?raw';
import AddExpenseModal from "../components/AddFundsModal.astro"; 

const WALLET_TYPE_MAP = {
    "Petty Cash": "cash",
    "Emergency Cash": "cash",
    "GCash": "e-wallet",
    "Maya Wallet": "e-wallet",
    "UnionBank Savings": "bank",
    "BDO Checkings": "bank",
};

function parseApiDate(value) {
    if (!value) return null;
    if (/^\d{4}-\d{2}-\d{2}$/.test(value)) {
        const [year, month, day] = value.split("-").map(Number);
        return new Date(year, month - 1, day);
    }
    return new Date(value);
}

function formatTransactionDate(value) {
    const date = parseApiDate(value);
    return date && !Number.isNaN(date.getTime())
        ? date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
        : "";
}

let wallets = [];
try {
    const res = await fetch("http://127.0.0.1:8000/api/expenses/wallets/", {
        headers: { Accept: "application/json" },
    });
    if (res.ok) {
        const data = await res.json();
        const list = data.results || data;
        wallets = list.map((w) => ({
            id: w.id,
            name: w.name,
            description: w.description,
            amount: parseFloat(w.balance || 0),
            type: WALLET_TYPE_MAP[w.name] || "cash",
            created_at: w.created_at,
            updated_at: w.updated_at,
        }));
    }
} catch (_) {}

let transactions = [];
try {
    const res = await fetch("http://127.0.0.1:8000/api/expenses/transactions/?limit=20", {
        headers: { Accept: "application/json" },
    });
    if (res.ok) {
        const data = await res.json();
        const rawList = data.results || data;
        const list = rawList.slice().sort((a, b) => {
            const dateDiff = new Date(b.transaction_date).getTime() - new Date(a.transaction_date).getTime();
            if (dateDiff !== 0) return dateDiff;
            return (b.id || 0) - (a.id || 0);
        });
        transactions = list.map((t) => ({
            id: t.id,
            amount: t.amount,
            wallet_name: t.wallet_name,
            category: t.category,
            category_label: t.BIR_label || t.category,
            transaction_type: t.transaction_type,
            note: t.note || "--",
            user_name: t.user_name || "User 1",
            transaction_date: t.transaction_date,
        }));
    }
} catch (_) {}

const totalBalanceCalculated = wallets.reduce(
    (sum, wallet) => sum + wallet.amount,
    0
);

const walletPartitions = wallets.map(wallet => ({
    ...wallet,
    percentage: totalBalanceCalculated > 0 ? (wallet.amount / totalBalanceCalculated) * 100 : 0
}));

const totalBalance = `₱${totalBalanceCalculated.toLocaleString("en-PH", {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
})}`;

const partitionColors = [
    "#F5C842",
    "#4B7FE8",
    "#2EC4A0",
    "#E86D8A",
    "#8D6BE8",
    "#FF914D",
    "#64C864",
    "#5DC1D6"
];

---

<Layout>
    <div class="dashboard-page">
        <div class="dashboard-inner">
            <div class="top-section">
                <div class="balancecard">
                    <button
                        id="show-balance"
                        type="button"
                        aria-label="Hide balance"
                        aria-pressed="false"
                        class="absolute z-10 top-6 right-5 w-12 h-12 flex justify-center items-center rounded-2xl bg-white/20 cursor-pointer"
                        set:html={IconBalanceShow}>
                    </button>
                    <div class="balancecard-heading">
                        <p>TOTAL BALANCE</p>
                    </div>
                    <div
                        id="balance-amount"
                        class="balancecard-amount truncate"
                        data-balance={totalBalance}
                    >
                        {totalBalance}
                    </div>
                    <div class="balancecard-partitions">
                        {
                            walletPartitions.map((wallet, index) => (
                                <div
                                    class="partition-wrapper"
                                    style={`flex:${wallet.percentage}`}
                                >
                                    <span
                                        class="seg"
                                        style={`background:${partitionColors[index % partitionColors.length]}`}
                                    ></span>

                                    <div class="partition-tooltip">
                                        <strong>{wallet.name}</strong><br />
                                        ₱{wallet.amount.toLocaleString("en-PH", {
                                            minimumFractionDigits: 2,
                                            maximumFractionDigits: 2
                                        })}
                                        <br />
                                        {wallet.percentage.toFixed(1)}%
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                    <div class="balancecard-action-buttons">
                        <button class="card-button" data-modal="add-funds-modal"><span set:html={IconAddFunds}></span>Add Funds</button>
                        <button class="card-button" data-modal="spend-funds-modal" id = "spend-funds-button"><span set:html={IconSpendFunds}></span>Spend Funds</button>
                        <button class="card-button" data-modal="move-funds-modal"><span set:html={IconMoveFunds}></span>Move Funds</button>
                    </div>
                </div>

                <div class="wallets-section">
                    <div class="wallets-header">
                        <span>Wallets</span>
                        <a href="/wallets">See All</a>
                    </div>
                    <div class="wallets-scrollable">
                        <div class="wallets-group">
                            {
                                wallets.map((wallet) => (
                                    <div class="dashboard-wallet-item">
                                        <WalletCard
                                            name={wallet.name}
                                            amount={`₱${wallet.amount.toLocaleString("en-PH", {
                                                minimumFractionDigits: 2,
                                                maximumFractionDigits: 2
                                            })}`}
                                            type={wallet.type as "cash" | "e-wallet" | "bank"}
                                        />
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="metric-container">
                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">INCOMING FUNDS THIS MONTH</span>
                        <span class="metric-value" id="dash-incoming-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={IconCashUp} />
                    </div>
                </div>
                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">OUTGOING FUNDS THIS MONTH</span>
                        <span class="metric-value" id="dash-outgoing-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={IconCashDown} />
                    </div>
                </div>
                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">TOTAL PROFIT THIS MONTH</span>
                        <span class="metric-value" id="dash-profit-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={IconCash} />
                    </div>
                </div>
                <div class="metric-card">
                    <div class="metric-info">
                        <span class="metric-label">TRANSACTIONS THIS MONTH</span>
                        <span class="metric-value" id="dash-transactions-value">---</span>
                    </div>
                    <div class="metric-icon-wrapper">
                        <Fragment set:html={IconTransaction} />
                    </div>
                </div>
            </div>

            <div class="graph-section">
                <div class="graph-card">
                    <span class="graph-label orange">TOTAL INCOMING VS OUTGOING THIS MONTH</span>
                    <div class="graph-content"><DashboardIncomeVsOutgoing /></div>
                </div>
                <div class="graph-card">
                    <span class="graph-label orange">INCOMING FUNDS BY WALLET SOURCE</span>
                    <div class="graph-content"><DashboardIncomingByWallet /></div>
                </div>
                <div class="graph-card">
                    <span class="graph-label orange">OUTGOING FUNDS BY EXPENSE CATEGORY</span>
                    <div class="graph-content"><DashboardExpensesByCategory /></div>
                </div>
            </div>

            <div class="transaction-history">
                <div class="transaction-headings blue">
                    <div class="transaction-top-row">
                        <div>
                            <p>RECENT TRANSACTIONS</p>
                            <p>Showing results for </p>
                        </div>
                        <div class="filtergroup">
                            <button class="filter-chip active" data-filter="all">All</button>
                            <button class="filter-chip" data-filter="added">Added Funds</button>
                            <button class="filter-chip" data-filter="spent">Spent Funds</button>
                        </div>
                    </div>
                    <div class="transactionlabels">
                        <p>AMOUNT</p>
                        <p>WALLET</p>
                        <p>CATEGORY</p>
                        <p>NOTE</p>
                        <p>USER</p>
                        <p>DATE</p>
                    </div>
                </div>

                <div class="transaction-history-scrollable">
                    <div class="transaction-history-slots" id="recent-transactions">
                        {transactions.length === 0 ? (
                            <div class="transactionrow">
                                <p colspan="6" style="text-align:center;opacity:0.5">No transactions yet</p>
                            </div>
                        ) : (
                            transactions.map((t) => {
                                const isAdd = t.transaction_type === "add funds";
                                const isSpend = t.transaction_type === "spend funds";
                                const color = isAdd ? "#2ecc71" : (isSpend ? "#e74c3c" : "#f39c12");
                                const sign = isAdd ? "+" : (isSpend ? "-" : "~");
                                const amt = Number(t.amount).toLocaleString("en-PH", {minimumFractionDigits:2});
                                return <div class="transactionrow">
                                    <p style={`color:${color};font-weight:600`}>{sign}₱{amt}</p>
                                    <p>{t.wallet_name}</p>
                                    <p>{t.category_label || t.category}</p>
                                    <p>{t.note}</p>
                                    <p>{t.user_name}</p>
                                    <p>{formatTransactionDate(t.transaction_date)}</p>
                                </div>;
                            })
                        )}
                    </div>
                </div>

            </div>

        </div>
    </div>
</Layout>

    <!-- Add Funds Modal -->
    <div id="add-funds-modal" class="modal-overlay" aria-hidden="true">
        <div class="modal modal--navy" role="dialog" aria-modal="true" aria-labelledby="add-funds-title">
            <div class="modal-header">
                <div class="modal-header-left">
                    <span class="modal-header-icon"><Fragment set:html={IconCashDown} /></span>
                    <h2 id="add-funds-title">Add Funds</h2>
                </div>
                <button class="modal-close" aria-label="Close modal">✕</button>
            </div>

            <div class="modal-body">

                <!-- Fund Amount -->
                <div class="form-group">
                    <label for="fund-amount">FUND AMOUNT</label>
                    <div class="input-icon-wrapper">
                        <span class="input-icon"><Fragment set:html={IconPeso} /></span>
                        <input id="fund-amount" name="amount" type="number" min="0" step="1" placeholder="Enter Amount" />
                    </div>
                </div>

                <!-- Destination Wallet -->
                <div class="form-group">
                    <label for="fund-wallet">DESTINATION WALLET</label>
                    <div class="input-icon-wrapper">
                        <span class="input-icon"><Fragment set:html={IconWallet} /></span>
                        <select id="fund-wallet" name="wallet">
                            <option value="" disabled selected>Select Wallet</option>
                            {
                                wallets.map((wallet) => (
                                    <option value={wallet.id}>
                                        {wallet.name}
                                    </option>
                                ))
                            }
                        </select>
                    </div>
                </div>

                <!-- Advanced Toggle -->
                <div class="advanced-toggle-wrapper">
                    <button type="button" class="advanced-toggle" id="advanced-toggle-add">
                        Advanced <span class="advanced-arrow" set:html={IconChevronDown}></span>
                    </button>
                    <div class="advanced-divider"></div>
                </div>

                <!-- Advanced Fields (hidden by default) -->
                <div class="advanced-fields" id="advanced-fields-add">

                    <!-- Note -->
                    <div class="form-group">
                        <label for="fund-note">NOTE</label>
                        <textarea id="fund-note" name="note" rows="3" placeholder="Add a note about this transaction..."></textarea>
                    </div>

                    <!-- Date + Attachment side by side -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="fund-date">DATE</label>
                            <div class="input-icon-wrapper">
                                <input id="fund-date" name="date" type="date" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="fund-attachment-input">ATTACHMENT</label>
                            <label class="file-upload-wrapper" for="fund-attachment-input">
                                <span class="placeholder-text" id="fund-attachment-filename">Select files</span>
                                <span class="input-icon-right"><Fragment set:html={IconAttachment} /></span>
                            </label>
                            <input type="file" id="fund-attachment-input" name="attachment" accept="image/*" style="display: none;" />
                        </div>
                    </div>

                </div>
            </div>

            <div class="modal-footer modal-footer--stack">
                <button type="button" class="btn-save-another" onclick="window.submitAddFunds?.(true)">Save and Add Another</button>
                <div class="modal-footer-row">
                    <button type="button" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary btn-primary--navy" onclick="window.submitAddFunds?.(false)">Add Fund</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Move Funds Modal -->
    <div id="move-funds-modal" class="modal-overlay" aria-hidden="true">
        <div class="modal modal--grey" role="dialog" aria-modal="true" aria-labelledby="move-funds-title">
            <div class="modal-header">
                <div class="modal-header-left">
                    <span class="modal-header-icon"><Fragment set:html={IconMoveFunds} /></span>
                    <h2 id="move-funds-title">Move Funds</h2>
                </div>
                <button class="modal-close" aria-label="Close modal">✕</button>
            </div>

            <div class="modal-body">

                <!-- Fund Amount -->
                <div class="form-group">
                    <label for="move-amount">FUND AMOUNT</label>
                    <div class="input-icon-wrapper">
                        <span class="input-icon"><Fragment set:html={IconPeso} /></span>
                        <input id="move-amount" name="amount" type="number" min="0" step="1" placeholder="Enter Amount" />
                    </div>
                </div>

                <!-- Source + Destination Wallet side by side -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="move-source">SOURCE WALLET</label>
                        <div class="input-icon-wrapper">
                            <span class="input-icon"><Fragment set:html={IconWallet} /></span>
                            <select id="move-source" name="source_wallet">
                                <option value="" disabled selected>Select Wallet</option>
                                {wallets.map((wallet) => (
                                    <option value={wallet.id}>{wallet.name}</option>
                                ))}
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="move-destination">DESTINATION WALLET</label>
                        <div class="input-icon-wrapper">
                            <span class="input-icon"><Fragment set:html={IconWallet} /></span>
                            <select id="move-destination" name="destination_wallet">
                                <option value="" disabled selected>Select Wallet</option>
                                {wallets.map((wallet) => (
                                    <option value={wallet.id}>{wallet.name}</option>
                                ))}
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Advanced Toggle -->
                <div class="advanced-toggle-wrapper">
                    <button type="button" class="advanced-toggle" id="advanced-toggle-move">
                        Advanced <span class="advanced-arrow" set:html={IconChevronDown}></span>
                    </button>
                    <div class="advanced-divider"></div>
                </div>

                <!-- Advanced Fields -->
                <div class="advanced-fields" id="advanced-fields-move">
                    <div class="form-group">
                        <label for="move-note">NOTE</label>
                        <textarea id="move-note" name="note" rows="3" placeholder="Add a note about this transaction..."></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="move-date">DATE</label>
                            <div class="input-icon-wrapper">
                                <input id="move-date" name="date" type="date" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="move-attachment-input">ATTACHMENT</label>
                            <label class="file-upload-wrapper" for="move-attachment-input">
                                <span class="placeholder-text" id="move-attachment-filename">Select files</span>
                                <span class="input-icon-right"><Fragment set:html={IconAttachment} /></span>
                            </label>
                            <input type="file" id="move-attachment-input" name="attachment" accept="image/*" style="display: none;" />
                        </div>
                    </div>
                </div>

            </div>

            <div class="modal-footer modal-footer--stack">
                <button type="button" class="btn-save-another btn-save-another--grey">Save and Add Another</button>
                <div class="modal-footer-row">
                    <button type="button" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary--move">Move Fund</button>
                </div>
            </div>
        </div>
    </div>
<AddExpenseModal />

<script>
    import "../scripts/dashboard-metrics.js";
</script>

<script define:vars={{ wallets }}>
    window.wallets = wallets;
</script>

<script is:inline>
    function openModal(modal) {
        if (!modal) return;
        modal.classList.add('open');
        modal.setAttribute('aria-hidden', 'false');
    }

    function closeModal(modal) {
        if (!modal) return;
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
    }

    async function reloadDashboard(modalId = null) {
        if (modalId) {
            sessionStorage.setItem('kwentadoor:reopen-modal', modalId);
        }
        await new Promise(resolve => setTimeout(resolve, 200));
        window.location.reload();
    }

    async function submitAddFunds(keepOpen) {
        const wallet = document.getElementById('fund-wallet');
        const amount = document.getElementById('fund-amount');
        const note = document.getElementById('fund-note');
        const dateInput = document.getElementById('fund-date');

        if (!wallet || !amount) return;

        const fundAmount = Number(amount.value);

        if (isNaN(fundAmount) || fundAmount <= 0) {
            alert("Fund amount must be greater than 0.");
            return;
        }

        wallet.setAttribute('disabled', '');
        amount.setAttribute('disabled', '');

        const btn = document.querySelector('#add-funds-modal .btn-primary--navy');
        const originalText = btn?.textContent || '';

        if (btn) {
            btn.textContent = 'Saving...';
            btn.setAttribute('disabled', '');
        }

        try {
            await window.__addFunds({
                wallet: wallet.value,
                amount: amount.value,
                note: note?.value || '',
                transaction_date: dateInput?.value || '',
            });

            if (btn) {
                btn.textContent = originalText;
                btn.removeAttribute('disabled');
            }

            document.dispatchEvent(new CustomEvent('funds-added'));

            if (keepOpen) {
                amount.value = '';
                note.value = '';
                dateInput.value = '';
                wallet.value = '';
                if (wallet.options.length > 0) wallet.selectedIndex = 0;
                await reloadDashboard('add-funds-modal');
            } else {
                closeModal(document.getElementById('add-funds-modal'));
                await reloadDashboard();
            }

        } catch (e) {
            if (btn) {
                btn.textContent = originalText;
                btn.removeAttribute('disabled');
            }
            alert('Add funds failed');
        } finally {
            wallet.removeAttribute('disabled');
            amount.removeAttribute('disabled');
        }
    }

    window.submitAddFunds = submitAddFunds;

    async function submitMoveFunds(keepOpen) {
        const source = document.getElementById('move-source');
        const dest = document.getElementById('move-destination');
        const amount = document.getElementById('move-amount');
        const note = document.getElementById('move-note');
        const dateInput = document.getElementById('move-date');

        if (!source || !dest || !amount) return;

        const transferAmount = Number(amount.value);

        if (isNaN(transferAmount) || transferAmount <= 0) {
            alert("Transfer amount must be greater than 0.");
            return;
        }

        const sourceWallet = window.wallets.find(
            w => String(w.id) === String(source.value)
        );

        if (!sourceWallet) {
            alert("Please select a valid source wallet.");
            return;
        }

        if (transferAmount > Number(sourceWallet.amount)) {
            alert(
                `Insufficient funds.\nAvailable balance: ₱${Number(sourceWallet.amount).toLocaleString("en-PH", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
                })}`
            );
            return;
        }

        if (source.value === dest.value) {
            alert("Source and destination wallets must be different.");
            return;
        }

        source.setAttribute('disabled', '');
        dest.setAttribute('disabled', '');
        amount.setAttribute('disabled', '');

        const btn = document.querySelector('#move-funds-modal .btn-primary--move');
        const originalText = btn?.textContent || '';

        if (btn) {
            btn.textContent = 'Saving...';
            btn.setAttribute('disabled', '');
        }

        try {
            await window.__moveFunds({
                from_wallet: source.value,
                to_wallet: dest.value,
                amount: amount.value,
                note: note?.value || '',
                transaction_date: dateInput?.value || '',
            });

            if (btn) {
                btn.textContent = originalText;
                btn.removeAttribute('disabled');
            }

            if (keepOpen) {
                amount.value = '';
                source.value = '';
                dest.value = '';
                note.value = '';
                dateInput.value = '';
                await reloadDashboard('move-funds-modal');
            } else {
                closeModal(document.getElementById('move-funds-modal'));
                document.dispatchEvent(new CustomEvent('funds-moved'));
                await reloadDashboard();
            }

        } catch (e) {
            if (btn) {
                btn.textContent = originalText;
                btn.removeAttribute('disabled');
            }
            alert('Move funds failed');
        } finally {
            source.removeAttribute('disabled');
            dest.removeAttribute('disabled');
            amount.removeAttribute('disabled');
        }
    }

    document.addEventListener("astro:page-load", async () => {
        const reopenModalId = sessionStorage.getItem('kwentadoor:reopen-modal');
        if (reopenModalId) {
            sessionStorage.removeItem('kwentadoor:reopen-modal');
            if (reopenModalId === 'addExpenseModal') {
                document.getElementById('addExpenseModal')?.showModal();
            } else {
                openModal(document.getElementById(reopenModalId));
            }
        }

        const toggle = document.getElementById("show-balance");
        const balance = document.getElementById("balance-amount");

        if (toggle && balance) {
            let isVisible = true;

            function renderBalance() {
                const actualBalance = balance.dataset.balance ?? "";
                balance.style.opacity = "0";
                balance.style.transform = "translateY(6px)";

                if (isVisible) {
                    balance.textContent = actualBalance;
                    balance.classList.remove("balance-hidden");
                    toggle.setAttribute("aria-label", "Hide balance");
                    toggle.setAttribute("aria-pressed", "false");
                } else {
                    balance.textContent = "₱ ••••••••••";
                    balance.classList.add("balance-hidden");
                    toggle.setAttribute("aria-label", "Show balance");
                    toggle.setAttribute("aria-pressed", "true");
                }

                requestAnimationFrame(() => {
                    balance.style.opacity = "1";
                    balance.style.transform = "translateY(0)";
                });
            }

            toggle.addEventListener("click", () => {
                isVisible = !isVisible;
                renderBalance();
            });

            renderBalance();
        }

        const chips = document.querySelectorAll(".filter-chip");
        const transactionLabel = document.querySelector(".transaction-top-row div p:nth-child(2)");

        chips.forEach((chip) => {
            chip.addEventListener("click", () => {
                chips.forEach((c) => c.classList.remove("active"));
                chip.classList.add("active");

                const filter = chip.dataset.filter;

                if (transactionLabel) {
                    switch (filter) {
                        case "added":
                            transactionLabel.textContent = "Showing results for Added Funds";
                            break;
                        case "spent":
                            transactionLabel.textContent = "Showing results for Spent Funds";
                            break;
                        default:
                            transactionLabel.textContent = "Showing results for All Transactions";
                    }
                }

                window.__loadRecentTransactions?.(filter);
            });
        });

        document.querySelectorAll("[data-modal]").forEach(trigger => {
            trigger.addEventListener("click", () => {
                const modal = document.getElementById(trigger.dataset.modal);
                if (!modal) return;
                openModal(modal);
            });
        });

        document.querySelectorAll(".modal-overlay").forEach(modal => {

            // modal.addEventListener("click", e => {
            //     if (e.target === modal) closeModal(modal);
            // });

            modal.querySelector(".modal-close")
                ?.addEventListener("click", () => closeModal(modal));

            modal.querySelector(".btn-secondary")
                ?.addEventListener("click", () => closeModal(modal));
        });

        document.addEventListener("keydown", e => {
            if (e.key !== "Escape") return;

            document
                .querySelectorAll(".modal-overlay.open")
                .forEach(closeModal);
        });

        document.querySelectorAll(".advanced-toggle").forEach(btn => {
            btn.onclick = () => {
                const targetId = btn.id.replace("advanced-toggle", "advanced-fields");
                const fields = document.getElementById(targetId);

                if (!fields) return;

                const isOpen = fields.classList.toggle("open");
                btn.classList.toggle("open", isOpen);
            };
        });

        function wireAttachmentPreview(inputId, labelId) {
            const input = document.getElementById(inputId);
            const label = document.getElementById(labelId);
            if (!input || !label) return;

            input.addEventListener("change", () => {
                label.textContent = input.files?.[0]?.name || "Select files";
            });
        }

        wireAttachmentPreview("fund-attachment-input", "fund-attachment-filename");
        wireAttachmentPreview("move-attachment-input", "move-attachment-filename");

        document.querySelector("#add-funds-modal .btn-primary--navy")
            ?.addEventListener("click", () => submitAddFunds(false));

        document.querySelector("#add-funds-modal .btn-save-another")
            ?.addEventListener("click", () => submitAddFunds(true));

        document.querySelector("#move-funds-modal .btn-primary--move")
            ?.addEventListener("click", () => submitMoveFunds(false));

        document.querySelector("#move-funds-modal .btn-save-another")
            ?.addEventListener("click", () => submitMoveFunds(true));
    });

    const spendBtn = document.getElementById("spend-funds-button");
    const spendModal = document.getElementById("addExpenseModal");

    console.log(spendBtn);
    console.log(spendModal);

    spendBtn?.addEventListener("click", () => {
        console.log("clicked");
        spendModal.showModal();
    });
</script>

