---
import '../styles/global.css';
import trabahadoorLogo from '../assets/trabahadoor-logo.svg?raw';
import logo from '../assets/Trabahadoor-logo-white.svg';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Kwentadoor</title>
  <link rel="icon" type="image/svg+xml" href={logo} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;550;700&display=swap" rel="stylesheet">
</head>
<body>
  <main id="main-container">
    
    <section id="login-text-container">
      <div class="brand-wrapper">
        <div id="company-logo-and-name">
          <Fragment set:html={trabahadoorLogo} />
          <h1>
            <span class="text-navy">Kwenta</span><span class="text-orange">Door</span>
          </h1>
        </div>
        <p class="title-text">TrabahaDoor's internal accounting web app</p>
        <p class="paragraph-text">Log incoming and outgoing funds with friendly terminologies without the complicated BIR jargon.</p>
      </div>
    </section>

    <section id="login-form-main-container">
      <div class="form-wrapper">
        
        <div id="login-header">
          <img src={logo} alt="Trabahadoor Logo" height="50" width="50"/>
          <h2>Kwenta<span class="text-orange">Door</span></h2>
        </div>

        <form id="login-form">
          <div id="login-welcome">
            <h2>Welcome back!</h2>
            <p>Login to <span class="embolden">KwentaDoor</span></p>
          </div>
        
          <div id="error-message" class="hidden"></div>

          <div class="input-group">
            <label for="username">USERNAME</label>
            <input 
              id="username" name="username" type="text" required 
              placeholder="Enter username"
            />
          </div>
          
          <div class="input-group">
            <label for="password">PASSWORD</label>
            <input 
              id="password" name="password" type="password" required 
              placeholder="Enter password"
            />
          </div>

          <button type="submit" id="submit-btn" >
            <span>Login</span>
          </button>
        </form>

      </div>
    </section>
  </main>

  <script>
    if (localStorage.getItem('auth_token')) {
        window.location.replace('/dashboard');
    }

    const BASE = import.meta.env.PUBLIC_API_URL || 'https://accounting-api.advancedthinkers.app/api';
    const form = document.getElementById('login-form');
    const errorMessage = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = submitBtn.querySelector('span');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (errorMessage) errorMessage.classList.add('hidden');
      submitBtn.disabled = true;
      if (btnText) btnText.textContent = 'Signing in...';

      const formData = new FormData(form);
      const username = formData.get('username');
      const password = formData.get('password');

      try {
        const response = await fetch(`${BASE}/auth/login/`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ username, password }),
        });

        let data;
        try {
          data = await response.json();
        } catch (parseError) {
          throw new Error("Server returned a non-JSON response.");
        }

        if (response.ok) {
          localStorage.setItem('auth_token', data.token);
          localStorage.setItem('user_data', JSON.stringify(data.user));
          window.location.href = '/dashboard';
        } else {
          let errorText = 'Invalid username or password. Please try again.';
          if (data.non_field_errors && data.non_field_errors.length > 0) {
            errorText = data.non_field_errors;
          } else if (data.detail) {
            errorText = data.detail;
          }
            
          if (errorMessage) {
            errorMessage.textContent = errorText;
            errorMessage.classList.remove('hidden');
          }
        }
      } catch (error) {
        console.error('Login error:', error);
        if (errorMessage) {
          errorMessage.textContent = 'Unable to connect to the server. Please check your connection.';
          errorMessage.classList.remove('hidden');
        }
      } finally {
        submitBtn.disabled = false;
        if (btnText) btnText.textContent = 'Login';
      }
    });
  </script>

<style>

  #main-container{
    padding: var(--space-lg) var(--space-lg);
    flex: 1;
    overflow-y: auto;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 10px,
      #e2e8f0 10px,
      #e2e8f0 11px
    );
    z-index: -1;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    min-height: 100vh;
    width: 100%;
    font-family: var(--general-text-font, 'Roboto', sans-serif);
  }

  #login-text-container {
    flex: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 4vw, 4rem);
  }

  .brand-wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 650px;
    width: 100%;
    margin-bottom: clamp(2rem, 8vw, 10rem);
  }

  #company-logo-and-name {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 15px; 
    margin-bottom: 1rem;
  }

  #company-logo-and-name :global(svg) {
    width: clamp(70px, 10vw, 106px);
    height: auto;
  }

  h1 {
    font-family: var(--display-headings-font);
    font-weight: 800;
    font-size: clamp(2.3rem, 6vw, 4rem);
    margin: 0;
  }

  .text-navy { color: var(--primary-navyblue); }
  .text-orange { color: var(--primary-orange); }

  .title-text {
    font-weight: 800;
    margin: 0 0 10px 0;
    font-family: var(--display-headings-font);
    color: var(--primary-navyblue);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
  }

  .paragraph-text {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    margin: 0;
    font-family: var(--general-text-font);
    color: var(--primary-navyblue); 
    font-weight: 550;
  }

  #login-form-main-container {
    flex: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .form-wrapper {
    width: min(100%, 400px);
    min-height: 531px;
    padding: 20px;
    border-radius: 25px;
    box-shadow: var(--default-shadow);
    display: flex;
    flex-direction: column;
    background: var(--white);
  }

  #login-header {
    text-align: center;
    margin-bottom: 1.5rem;
    margin: -20px -20px 0px -20px ;
    border-radius: 25px 25px 0px 0px;
    background-image: var(--navyblue-gradient);
    padding: 20px 20px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
  }

  #login-header h2 {
    font-family: var(--display-headings-font);
    margin: 10px 0 5px 0;
    color: var(--white);
    font-weight: 800;
    font-size: var(--title-text);
  }

  #login-header :global(svg){
    height: 50px;
    width: 55px;
  }

  #login-form{
    box-sizing: border-box;
    padding-top: 30px;
    flex: 1; 
    display: flex; 
    flex-direction: column;
  }

  #login-welcome{
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 30px;
  }

  #login-welcome h2{
    font-family: var(--display-headings-font);
    font-size: var(--title-text);
    color: var(--primary-navyblue);
    font-weight: bold;
  }

  #login-welcome p{
    font-family: var(--general-text-font);
    font-size: var(--paragraph-text);
    color: #000000;
    opacity: 50%;
    font-weight: bold;
  }

  .embolden{
    font-weight: bold;
    font-family: var(--display-headings-font);
  }

  #error-message {
    background-color: rgba(220, 38, 38, 0.1); 
    border: 1px solid rgba(220, 38, 38, 0.4);
    color: #dc2626;
    padding: 10px;
    border-radius: 10px;
    font-size: var(--paragraph-text, 14px);
    text-align: center;
    margin-bottom: 1rem;
    width: 100%;
    box-sizing: border-box;
    font-weight: 550;
  }

  .hidden {
    display: none !important;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }

  .input-group label {
    margin-bottom: 5px;
    margin-left: 10px;
    font-weight: bold;
    font-size: var(--paragraph-text);
    color: #000000;
    opacity: 50%;
    font-weight: 400;
  }

  .input-group input {
    padding: 10px;
    border-radius: 15px;
    background-color: rgba(0, 0, 0, 0.05);
    color: #000; 
    font-size: var(--paragraph-text);
    font-family: var(--general-text-font);
    border: none;
    font-weight: 550;
  }

  #submit-btn {
    width: 100%;
    padding: 12px;
    margin-top: auto;
    background-color: var(--primary-orange, #F26B2A);
    color: white;
    border: none;
    border-radius: 15px;
    font-size: var(--paragraph-text);
    font-weight: bold;
    cursor: pointer;
  }

  #submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  @media (max-width: 900px) {
    #main-container {
      flex-direction: column;
      overflow-y: auto;
      padding-bottom: 30vh;
    }

    #login-text-container,
    #login-form-main-container {
      width: 100%;
      flex: none;
      padding: 2rem 1.5rem;
      align-items: center;
      justify-content: center;
    }

    .brand-wrapper {
      margin-bottom: 2rem;
      align-items: center;
      text-align: center;
    }

    #company-logo-and-name {
      justify-content: center;
    }

    .form-wrapper {
      width: 100%;
      max-width: 400px;
    }
  }

  @media (max-width: 600px) {

    #main-container {
      padding: 1rem;
      padding-bottom: 50vh;
    }

    #company-logo-and-name {
      gap: 10px;
    }

    #company-logo-and-name :global(svg) {
      width: 64px;
    }

    h1 {
      font-size: clamp(2rem, 8vw, 2.8rem);
    }

    .title-text {
      font-size: 1.15rem;
    }

    .paragraph-text {
      font-size: 0.95rem;
    }

    .form-wrapper {
      padding: 18px;
      border-radius: 20px;
    }

    #login-header {
      margin: -18px -18px 0 -18px;
    }
  }

</style>
</body>
</html>