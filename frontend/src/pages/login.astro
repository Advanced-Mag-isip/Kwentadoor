---
import '../styles/global.css';
import trabahadoorLogo from '../assets/trabahadoor-logo.svg?raw';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Kwentadoor</title>
  <link rel="icon" type="image/svg+xml" href="/src/assets/trabahadoor-logo.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;550;700&display=swap" rel="stylesheet">
</head>
<body>
  <main id="main-container">
    
    <section id="login-text-container">
      <div class="brand-wrapper">
        <div id="company-logo-and-name">
          <Fragment set:html={trabahadoorLogo} />
          <h1>
            <span class="text-navy">Kwenta</span><span class="text-orange">Door</span>
          </h1>
        </div>
        <p class="title-text">TrabahaDoor's internal accounting web app</p>
        <p class="paragraph-text">Log incoming and outgoing funds with friendly terminologies without the complicated BIR jargon.</p>
      </div>
    </section>

    <section id="login-form-main-container">
      <div class="form-wrapper">
        
        <div id="login-header">
          <img src="/src/assets/Trabahadoor-logo-white.svg" alt="Trabahadoor Logo" height="50" width="50"/>
          <h2>Kwenta<span class = "text-orange">Door</span></h2>
        </div>

      
        <form id="login-form">
          
          <div id = "login-welcome">
            <h2>Welcome back!</h2>
            <p>Login to <span class = "embolden">KwentaDoor</span></p>
          </div>
          

           <div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg p-3 text-center transition-all"></div>


          <div class="input-group">
            <label for="username">USERNAME</label>
            <input 
              id="username" name="username" type="text" required 
              placeholder="Enter username"
            />
          </div>
          
          <div class="input-group">
            <label for="password">PASSWORD</label>
            <input 
              id="password" name="password" type="password" required 
              placeholder="Enter password"
            />
          </div>

          <button type="submit" id="submit-btn">
            <span>Login</span>
          </button>
        </form>

      </div>
    </section>

  </main>

  <script lang="ts">
    const API_BASE_URL = 'http://127.0.0.1:8000';
    
    const form = document.getElementById('login-form') as HTMLFormElement;
    const errorMessage = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = submitBtn.querySelector('span');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if(errorMessage) errorMessage.classList.add('hidden');
      submitBtn.disabled = true;
      if (btnText) btnText.textContent = 'Signing in...';

      const formData = new FormData(form);
      const username = formData.get('username');
      const password = formData.get('password');

      try {
        const response = await fetch(`${API_BASE_URL}/api/auth/login/`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ username, password }),
        });

        const data = await response.json();

        if (response.ok) {
          localStorage.setItem('auth_token', data.token);
          localStorage.setItem('user_data', JSON.stringify(data.user));
          window.location.href = '/'; 
        } else {
          const errorText = data.non_field_errors 
            ? data.non_field_errors 
            : 'Invalid username or password. Please try again.';
            
          if (errorMessage) {
            errorMessage.textContent = errorText;
            errorMessage.classList.remove('hidden');
          }
        }
      } catch (error) {
        console.error('Login error:', error);
        if (errorMessage) {
          errorMessage.textContent = 'Unable to connect to the server. Please check your connection.';
          errorMessage.classList.remove('hidden');
        }
      } finally {
        submitBtn.disabled = false;
        if (btnText) btnText.textContent = 'Sign in';
      }
    });
  </script>
</body>

<style>
  #main-container {
    display: flex;
    flex-direction: row;
    height: 100vh;
    width: 100vw;
    font-family: var(--general-text-font, 'Roboto', sans-serif);
  }


  #login-text-container {
    width: 60%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .brand-wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 100%;
    margin-bottom: 10rem;
  }

  #company-logo-and-name {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 15px; 
    margin-bottom: 1rem;
  }

  #company-logo-and-name :global(svg) {
    width: 106px;
    height: auto;
  }

  h1 {
    font-family: var(--display-headings-font);
    font-weight: 800;
    font-size: 64px;  
    margin: 0;
  }

  .text-navy { color: var(--primary-navyblue); }
  .text-orange { color: var(--primary-orange); }

  .title-text {
    font-size: var(--title-text);
    font-weight: 800;
    margin: 0 0 10px 0;
    font-family: var(--display-headings-font);
    color: var(--primary-navyblue); 
  }

  .paragraph-text {
    font-size: var(--paragraph-text);
    margin: 0;
    font-family: var(--general-text-font);
    color: var(--primary-navyblue); 
    font-weight: 550;
  }


  #login-form-main-container {
    width: 40%; 
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .form-wrapper {
    width: 385px;
    height: 531px;
    max-width: 400px; 
    padding: 20px;
    border-radius: 25px; 
    box-shadow: var(--default-shadow);

    display: flex;
    flex-direction: column;
  }

  #login-header {
    text-align: center;
    margin-bottom: 1.5rem;
    margin: -20px -20px 0px -20px ;
    border-radius: 25px 25px 0px 0px;
    background-image: var(--navyblue-gradient);
    padding: 20px 20px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
  }

  #login-header h2 {
    font-family: var(--display-headings-font);
    margin: 10px 0 5px 0;
    color: var(--white);
    font-weight: 800;
    font-size: var(--title-text);
  }

  #login-header :global(svg){
    height: 50px;
    width: 55px;
  }

  #login-form{
    box-sizing: border-box;
    padding-top: 30px;

    flex: 1; 
  
  
    display: flex; 
    flex-direction: column;
  }

  #login-welcome{
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 30px;
  }

   #login-welcome h2{
    font-family: var(--display-headings-font);
    font-size: var(--title-text);
    color: var(--primary-navyblue);
    font-weight: bold;

  }

  #login-welcome p{
    font-family: var(--general-text-font);
    font-size: var(--paragraph-text);
    color: #000000;
    opacity: 50%;
    font-weight: bold; 
  }

  .embolden{
    font-weight: bold;
    font-family: var(--display-headings-font);

  }

  .input-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
    
  }

  .input-group label {
    margin-bottom: 5px;
    margin-left: 10px;
    font-weight: bold;
    font-size: var(--paragraph-text);
    color: #000000;
    opacity: 50%;
    font-weight: 400;
  }

.input-group input {
  padding: 10px;
  border-radius: 15px;
  background-color: rgba(0, 0, 0, 0.05); 
  color: #C2C2C2; 
  font-size: var(--paragraph-text);
  font-family: var(--general-text-font);
  border: none;
  font-weight: 550;
}
  #submit-btn {
    width: 100%;
    padding: 12px;
    margin-top: auto;
    background-color: var(--primary-orange, #F26B2A);
    color: white;
    border: none;
    border-radius: 15px;
    font-size: var(--paragraph-text);
    font-weight: bold;
    cursor: pointer;
  }

  #submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
</style>
</html>