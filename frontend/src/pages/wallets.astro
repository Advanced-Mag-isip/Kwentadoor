<script define:vars={{ IconCash, IconBank, IconEWallet }}>
    function closeModal(modal) {
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
    }

    document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        document.querySelectorAll('.modal-overlay.open').forEach(closeModal);
    });

    // Shared API helpers
    const API_BASE = "http://127.0.0.1:8000/api/expenses";

    function _authHeaders() {
        const token = localStorage.getItem("auth_token");
        return token ? { Authorization: "Token " + token } : {};
    }

    function apiFetch(path, options) {
        options = options || {};
        return fetch(API_BASE + path, {
            ...options,
            credentials: "include",
            headers: {
                "Content-Type": "application/json",
                Accept: "application/json",
                ..._authHeaders(),
                ...(options.headers || {}),
            },
        }).then(async (r) => {
            if (!r.ok) {
                const errorText = await r.text();
                if (!errorText) {
                    throw new Error(`Request failed with status ${r.status}`);
                }
                throw new Error(errorText);
            }

            if (r.status === 204 || r.status === 205) {
                return null;
            }

            const text = await r.text();
            if (!text) return null;

            try {
                return JSON.parse(text);
            } catch (_) {
                return text;
            }
        });
    }

    function reloadPage() {
        window.location.reload();
    }

    async function _populateAddFundsCategorySelect() {
        const sel = document.getElementById('fund-category');
        if (!sel) return;
        try {
            const data = await apiFetch('/categories/?type=income');
            const list = data.results || data;
            sel.innerHTML = '<option value="" disabled selected>Select Category</option>';
            list.forEach((c) => {
                const opt = document.createElement('option');
                opt.value = c.id;
                opt.textContent = c.label;
                sel.appendChild(opt);
            });
        } catch (e) {
            sel.innerHTML = '<option value="" disabled selected>No categories available</option>';
        }
    }

    // --- Wallet selection ---
    document.addEventListener("astro:page-load", () => {
        const walletIcons = {
            cash: IconCash,
            bank: IconBank,
            "e-wallet": IconEWallet
        };

        window.apiFetch = apiFetch;

        _populateAddFundsCategorySelect();

        const walletItems = document.querySelectorAll(".wallet-item");
        
        function setTodayDate(input) {
            if (input) {
                const today = new Date().toISOString().split('T')[0];
                input.value = today;
            }
        }

        function activateWalletItem(item) {
            if (!item) return;

            // Reset all
            walletItems.forEach(w => {
                w.classList.remove("active");
                const body = w.querySelector(".card-body");
                if (body) body.style.backgroundImage = "var(--navyblue-gradient)";
                const shell = w.querySelector(".card-shell");
                if (shell) shell.style.backgroundColor = "var(--primary-navyblue)";
            });

            // Activate clicked
            item.classList.add("active");
            const activeBody = item.querySelector(".card-body");
            if (activeBody) activeBody.style.backgroundImage = "var(--orange-gradient)";
            const activeShell = item.querySelector(".card-shell");
            if (activeShell) activeShell.style.backgroundColor = "var(--primary-orange-dark)";

            // Update balance card
            const walletName = document.getElementById("wallet-name");
            const walletDescription = document.getElementById("wallet-description");
            const walletAmount = document.getElementById("balance-amount");
            const walletIcon = document.getElementById("wallet-icon");

            if(walletName) walletName.textContent = item.dataset.name;
            if(walletDescription) walletDescription.textContent = item.dataset.description;

            const amount = Number(item.dataset.amount);
            if(walletAmount) {
                walletAmount.textContent = "₱" + amount.toLocaleString("en-PH", {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
                walletAmount.dataset.balance = amount;
            }

            if(walletIcon) {
                walletIcon.innerHTML = walletIcons[item.dataset.type] || IconCash;
            }

            // Update current wallet
            window.currentWallet = {
                id: item.dataset.id,
                name: item.dataset.name,
                description: item.dataset.description,
                amount: item.dataset.amount,
                type: item.dataset.type
            };

            if (typeof window.__loadRecentTransactions === 'function') {
                window.__loadRecentTransactions(window.__currentTransactionFilter);
            }
        }

        const savedWalletId = sessionStorage.getItem('activeWalletId');
        let walletToActivate = walletItems.length > 0 ? walletItems[0] : null;

        if (savedWalletId && walletItems.length > 0) {
            const found = Array.from(walletItems).find(w => w.dataset.id === savedWalletId);
            if (found) walletToActivate = found;
        }

        if (walletToActivate) {
            activateWalletItem(walletToActivate);
        }

        walletItems.forEach(item => {
            item.addEventListener("click", () => activateWalletItem(item));
        });

        function openModalWithPrefill(modal) {
            // Prefill edit modal
            if (modal.id === 'edit-wallet-modal') {
                const nameInput = document.getElementById('edit-wallet-name-input');
                const typeInput = document.getElementById('edit-wallet-type-input');
                const descInput = document.getElementById('edit-wallet-description-input');
                if (nameInput) nameInput.value = window.currentWallet.name || '';
                if (typeInput) typeInput.value = window.currentWallet.type || 'cash';
                if (descInput) descInput.value = window.currentWallet.description || '';
            }

            // Prefill delete modal
            if (modal.id === 'delete-wallet-modal') {
                const nameEl = document.getElementById('delete-wallet-name');
                const amountEl = document.getElementById('delete-wallet-amount');
                if (nameEl) nameEl.textContent = window.currentWallet.name || 'Wallet';
                if (amountEl) {
                    const amt = Number(window.currentWallet.amount) || 0;
                    amountEl.textContent = "₱" + amt.toLocaleString("en-PH", {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                }
            }

            if (modal.id === 'add-funds-modal') {
                const walletSelect = document.getElementById('fund-wallet');
                if (walletSelect && window.currentWallet && window.currentWallet.id) {
                    const option = Array.from(walletSelect.options).find(opt => opt.value === String(window.currentWallet.id));
                    if (option) {
                        walletSelect.value = window.currentWallet.id;
                    }
                }
                const dateInput = document.getElementById('fund-date');
                setTodayDate(dateInput);
            }

            if (modal.id === 'move-funds-modal') {
                const sourceSelect = document.getElementById('move-source');
                if (sourceSelect && window.currentWallet && window.currentWallet.id) {
                    const option = Array.from(sourceSelect.options).find(opt => opt.value === String(window.currentWallet.id));
                    if (option) {
                        sourceSelect.value = window.currentWallet.id;
                    }
                }
                const destSelect = document.getElementById('move-destination');
                if (destSelect) destSelect.value = ''; // Reset destination
                
                const dateInput = document.getElementById('move-date');
                setTodayDate(dateInput);
            }

            modal.classList.add('open');
            modal.setAttribute('aria-hidden', 'false');
        }

        // --- Modal opening logic ---
        document.querySelectorAll('[data-modal]').forEach(trigger => {
            trigger.addEventListener('click', () => {
                const modal = document.getElementById(trigger.dataset.modal);
                if (modal) openModalWithPrefill(modal);
            });
        });

        const reopenModalId = sessionStorage.getItem('reopenModal');
        if (reopenModalId) {
            sessionStorage.removeItem('reopenModal');
            sessionStorage.removeItem('activeWalletId');
            const modal = document.getElementById(reopenModalId);
            if (modal) {
                openModalWithPrefill(modal);
            }
        }

        // Close modal handlers
        document.querySelectorAll('.modal-overlay').forEach(modal => {
            // modal.addEventListener('click', (e) => {
            //     if (e.target === modal) closeModal(modal);
            // });
            modal.querySelector('.modal-close')?.addEventListener('click', () => closeModal(modal));
            modal.querySelectorAll('.btn-secondary').forEach(btn => {
                btn.addEventListener('click', () => closeModal(modal));
            });
        });

        // Advanced toggle
        document.querySelectorAll('.advanced-toggle').forEach(btn => {
            btn.onclick = () => {
                const targetId = btn.id.replace('advanced-toggle', 'advanced-fields');
                const fields = document.getElementById(targetId);
                if (!fields) return;

                const isOpen = fields.classList.toggle('open');
                btn.classList.toggle('open', isOpen);
            };
        });

        function wireAttachmentPreview(inputId, labelId) {
            const input = document.getElementById(inputId);
            const label = document.getElementById(labelId);
            if (!input || !label) return;

            input.addEventListener("change", () => {
                label.textContent = input.files?.[0]?.name || "Select files";
            });
        }

        wireAttachmentPreview("fund-attachment-input", "fund-attachment-filename");
        wireAttachmentPreview("move-attachment-input", "move-attachment-filename");

        // ---- SUBMIT HANDLERS ----

        // Add Wallet
        document.getElementById('add-wallet-submit')?.addEventListener('click', async () => {
            const name = document.getElementById('wallet-name-input')?.value.trim();
            const type = document.getElementById('wallet-type-input')?.value;
            const description = document.getElementById('wallet-description-input')?.value.trim();
            if (!name) { alert('Wallet name is required.'); return; }
            if (!type) { alert('Please select a wallet type.'); return; }

            try {
                await apiFetch('/wallets/', {
                    method: 'POST',
                    body: JSON.stringify({ name, type, description, balance: 0 })
                });
                reloadPage();
            } catch (e) {
                alert('Failed to create wallet: ' + e.message);
            }
        });

        // Edit Wallet
        document.getElementById('edit-wallet-submit')?.addEventListener('click', async () => {
            const id = window.currentWallet.id;
            if (!id) { alert('No wallet selected.'); return; }
            const name = document.getElementById('edit-wallet-name-input')?.value.trim();
            const type = document.getElementById('edit-wallet-type-input')?.value;
            const description = document.getElementById('edit-wallet-description-input')?.value.trim();
            if (!name) { alert('Wallet name is required.'); return; }
            if (!type) { alert('Please select a wallet type.'); return; }

            try {
                await apiFetch(`/wallets/${id}/`, {
                    method: 'PUT',
                    body: JSON.stringify({ name, type, description })
                });
                reloadPage();
            } catch (e) {
                alert('Failed to update wallet: ' + e.message);
            }
        });

        // Delete Wallet
        document.getElementById('delete-wallet-submit')?.addEventListener('click', async () => {
            const id = window.currentWallet.id;
            if (!id) { alert('No wallet selected.'); return; }
            if (!confirm(`Are you sure you want to delete "${window.currentWallet.name}"?`)) return;

            try {
                await apiFetch(`/wallets/${id}/`, {
                    method: 'DELETE'
                });
                reloadPage();
            } catch (e) {
                alert('Failed to delete wallet: ' + e.message);
            }
        });

        // Add Funds
        const addFundsSubmitBtn = document.getElementById('add-funds-submit');
        const addFundsSaveAnotherBtn = document.getElementById('add-funds-save-another');

        if (addFundsSubmitBtn && !addFundsSubmitBtn.dataset.bound) {
            addFundsSubmitBtn.dataset.bound = 'true';
            addFundsSubmitBtn.addEventListener('click', () => submitAddFunds(false));
        }
        if (addFundsSaveAnotherBtn && !addFundsSaveAnotherBtn.dataset.bound) {
            addFundsSaveAnotherBtn.dataset.bound = 'true';
            addFundsSaveAnotherBtn.addEventListener('click', () => submitAddFunds(true));
        }

        let addFundsInFlight = false;

        async function submitAddFunds(keepOpen) {
            if (addFundsInFlight) return;

            const walletSelect = document.getElementById('fund-wallet');
            const categorySelect = document.getElementById('fund-category');
            const amountInput = document.getElementById('fund-amount');
            const noteInput = document.getElementById('fund-note');
            const dateInput = document.getElementById('fund-date');

            const walletId = walletSelect?.value;
            const categoryId = categorySelect?.value;
            const amount = parseFloat(amountInput?.value);
            if (!walletId) { alert('Please select a wallet.'); return; }
            if (!categoryId) { alert('Please select a category.'); return; }
            if (isNaN(amount) || amount <= 0) { alert('Amount must be greater than 0.'); return; }

            addFundsInFlight = true;
            const activeBtn = keepOpen ? addFundsSaveAnotherBtn : addFundsSubmitBtn;
            const originalText = activeBtn ? activeBtn.textContent : '';
            if (addFundsSubmitBtn) addFundsSubmitBtn.disabled = true;
            if (addFundsSaveAnotherBtn) addFundsSaveAnotherBtn.disabled = true;
            if (activeBtn) activeBtn.textContent = 'Saving...';

            try {
                await apiFetch('/transactions/', {
                    method: 'POST',
                    body: JSON.stringify({
                        wallet: walletId,
                        amount: amount,
                        transaction_type: 'add funds',
                        category: categoryId,
                        note: noteInput?.value || '',
                        transaction_date: dateInput?.value || null,
                    })
                });
                if (keepOpen) {
                    sessionStorage.setItem('reopenModal', 'add-funds-modal');
                    sessionStorage.setItem('activeWalletId', window.currentWallet ? window.currentWallet.id : walletId);
                } else {
                    closeModal(document.getElementById('add-funds-modal'));
                }
                reloadPage();
            } catch (e) {
                alert('Failed to add funds: ' + e.message);
            } finally {
                addFundsInFlight = false;
                if (addFundsSubmitBtn) addFundsSubmitBtn.disabled = false;
                if (addFundsSaveAnotherBtn) addFundsSaveAnotherBtn.disabled = false;
                if (activeBtn) activeBtn.textContent = originalText;
            }
        }

        // Move Funds
        document.getElementById('move-funds-submit')?.addEventListener('click', () => submitMoveFunds(false));
        document.getElementById('move-funds-save-another')?.addEventListener('click', () => submitMoveFunds(true));

        async function submitMoveFunds(keepOpen) {
            const source = document.getElementById('move-source');
            const dest = document.getElementById('move-destination');
            const amountInput = document.getElementById('move-amount');
            const noteInput = document.getElementById('move-note');
            const dateInput = document.getElementById('move-date');

            const sourceId = source?.value;
            const destId = dest?.value;
            const amount = parseFloat(amountInput?.value);
            if (!sourceId) { alert('Please select a source wallet.'); return; }
            if (!destId) { alert('Please select a destination wallet.'); return; }
            if (sourceId === destId) { alert('Source and destination must be different.'); return; }
            if (isNaN(amount) || amount <= 0) { alert('Amount must be greater than 0.'); return; }

            const sourceWallet = Array.from(document.querySelectorAll('.wallet-item')).find(
                el => el.dataset.id === sourceId
            );
            if (sourceWallet) {
                const balance = parseFloat(sourceWallet.dataset.amount) || 0;
                if (amount > balance) {
                    alert(`Insufficient balance. Available: ₱${balance.toFixed(2)}`);
                    return;
                }
            }

            try {
                await apiFetch('/transfers/', {
                    method: 'POST',
                    body: JSON.stringify({
                        from_wallet: sourceId,
                        to_wallet: destId,
                        amount: amount
                    })
                });

                if (keepOpen) {
                    sessionStorage.setItem('reopenModal', 'move-funds-modal');
                    sessionStorage.setItem('activeWalletId', window.currentWallet ? window.currentWallet.id : sourceId);
                } else {
                    closeModal(document.getElementById('move-funds-modal'));
                }
                reloadPage();
            } catch (e) {
                alert('Failed to move funds: ' + e.message);
            }
        }
    });
</script>

<script is:inline>
    window.__loadRecentTransactions = function (filter) {
        filter = filter || window.__currentTransactionFilter || "all";
        window.__currentTransactionFilter = filter;

        var baseUrl = "http://127.0.0.1:8000/api/expenses/transactions/?limit=100";
        
        var typeValue = null;
        if (filter !== "all") {
            typeValue = filter === "added" ? "add funds" : "spend funds";
            baseUrl += "&transaction_type=" + encodeURIComponent(typeValue);
        }

        var _token = localStorage.getItem("auth_token");
        fetch(baseUrl, {
            credentials: "include",
            headers: {
                "Content-Type": "application/json",
                Accept: "application/json",
                ...(_token ? { Authorization: "Token " + _token } : {})
            }
        }).then(function (res) {
            if (!res.ok) throw new Error("Failed to fetch");
            return res.json();
        }).then(function (data) {
            var list = data.results || data;
            var container = document.getElementById("recent-transactions");

            if (!container) return;

            if (window.currentWallet && window.currentWallet.id) {
                list = list.filter(function(t) {
                    return String(t.wallet) === String(window.currentWallet.id) || t.wallet_name === window.currentWallet.name;
                });
            }

            if (typeValue) {
                list = list.filter(function(t) {
                    return t.transaction_type === typeValue;
                });
            }

            if (!list.length) {
                container.innerHTML =
                    '<div class="transactionrow">' +
                    '<p style="grid-column:1/-1;text-align:center;opacity:.5">' +
                    'No transactions yet' +
                    '</p>' +
                    '</div>';
                return;
            }

        list.sort(function(a, b) {
            var dateDiff = new Date(b.transaction_date).getTime() - new Date(a.transaction_date).getTime();
            if (dateDiff !== 0) return dateDiff;
            return (b.id || 0) - (a.id || 0);
        });

        function parseApiDateClient(value) {
            if (!value) return null;
            if (/^\d{4}-\d{2}-\d{2}$/.test(value)) {
                var parts = value.split("-").map(Number);
                return new Date(parts[0], parts[1] - 1, parts[2]);
            }
            return new Date(value);
        }

        container.innerHTML = list.map(function (t) {
            var amt = Number(t.amount).toLocaleString("en-PH", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });

            var d = parseApiDateClient(t.transaction_date);
           
            var dateStr = d ? d.toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric"
            }) : "";

            var note = t.note || "--";
           
            var uname = t.user_name || "User 1";
            var wname = t.wallet_name || "";
            var cat = t.BIR_label || t.category || "";

            var isAdd = t.transaction_type === "add funds";
            var isSpend = t.transaction_type === "spend funds";
            
            var color = isAdd ? "#2ecc71" : isSpend ? "#e74c3c" : "#f39c12";
            var sign = isAdd ? "+" : isSpend ? "-" : "~";
            
            return `
                <div class="transactionrow">
                    <p style="color:${color};font-weight:600">${sign}₱${amt}</p>
                    <p>${wname}</p>
                    <p>${cat}</p>
                    <p>${note}</p>
                    <p>${uname}</p>
                    <p>${dateStr}</p>
                </div>
            `;
        }).join("");
    }).catch(console.error);
};

function initWalletPage() {
    var chips = document.querySelectorAll(".filter-chip");
    var label = document.getElementById("transaction-filter-label");
    chips.forEach(function (chip) {
        chip.onclick = function () {
            chips.forEach(function (c) {
                c.classList.remove("active");
            });
            chip.classList.add("active");

            var filter = chip.dataset.filter;
            window.__currentTransactionFilter = filter;

            if (label) {
                switch (filter) {
                    case "added":
                        label.textContent = "Showing results for Added Funds";
                        break;
                    case "spent":
                        label.textContent = "Showing results for Spent Funds";
                        break;
                    default:
                        label.textContent = "Showing results for All Transactions";
                }
            }

            window.__loadRecentTransactions(filter);
        };
    });
}

function _loadInitialWalletTransactions() {
    window.__loadRecentTransactions("all");
}

if (document.readyState === 'complete') {
    initWalletPage();
    _loadInitialWalletTransactions();
} else {
    document.addEventListener('astro:page-load', initWalletPage);
    document.addEventListener('astro:page-load', _loadInitialWalletTransactions);
}

window.__spendFunds = async function (data) {

    const payload = {
        wallet: data.wallet || data.walletId,
        amount: parseFloat(data.amount),
        transaction_type: "spend funds",
        category: data.category || "Uncategorized",
        note: data.note || "",
        transaction_date: data.date || new Date().toISOString().split("T")[0]
    };

    if (!payload.wallet || isNaN(payload.amount)) {
        alert("Wallet and Amount are required.");
        return;
    }

    try {
        const authToken = localStorage.getItem("auth_token");
        const response = await fetch("http://127.0.0.1:8000/api/expenses/transactions/", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                Accept: "application/json",
                ...(authToken ? { Authorization: "Token " + authToken } : {})
            },
            body: JSON.stringify(payload)
        });

        if (!response.ok) {
            const errData = await response.json();
            throw new Error(errData.detail || JSON.stringify(errData));
        }

        window.location.reload();
    } catch (error) {
        console.error("Error spending funds:", error);
        alert("Failed to spend funds: " + error.message);
    }
};
</script>