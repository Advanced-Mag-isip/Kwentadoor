---
import Layout from '../layouts/Layout.astro';
import WalletCard from '../components/WalletCard.astro';
import IconAddFunds from '../assets/add-funds-icon.svg?raw'; 
import IconSpendFunds from '../assets/spend-funds-icon.svg?raw';
import IconMoveFunds from '../assets/move-funds-icon.svg?raw';
import IconCash from "../assets/cash-icon.svg?raw";
import IconBank from "../assets/bank-icon.svg?raw";
import IconEWallet from "../assets/gcash-icon.svg?raw";
import IconEdit from "../assets/pen-line-icon.svg?raw";
import IconDelete from "../assets/trash-2-icon.svg?raw";
import IconChevronDown from '../assets/chevron-down.svg?raw';
import IconInfo from '../assets/information-icon.svg?raw';
import IconCashUp from '../assets/cash-up-icon.svg?raw'; 
import IconCashDown from '../assets/cash-down-arrow.svg?raw'; 
import IconWallet from '../assets/wallet-icon.svg?raw';
import IconPeso from '../assets/philippine-peso.svg?raw';
import IconAttachment from '../assets/paperclip.svg?raw';
import AddExpenseModal from "../components/AddFundsModal.astro";

const WALLET_TYPE_MAP = {
  "Petty Cash": "cash",
  "Emergency Cash": "cash",
  "GCash": "e-wallet",
  "Maya Wallet": "e-wallet",
  "UnionBank Savings": "bank",
  "BDO Checkings": "bank",
};

const walletType = {
  cash: { icon: IconCash },
  bank: { icon: IconBank },
  "e-wallet": { icon: IconEWallet },
};

function parseApiDate(value) {
    if (!value) return null;
    if (/^\d{4}-\d{2}-\d{2}$/.test(value)) {
        const [year, month, day] = value.split("-").map(Number);
        return new Date(year, month - 1, day);
    }
    return new Date(value);
}

function formatTransactionDate(value) {
    const date = parseApiDate(value);
    return date && !Number.isNaN(date.getTime())
        ? date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
        : "";
}

let wallets = [];
try {
  const res = await fetch("http://127.0.0.1:8000/api/expenses/wallets/", {
    headers: { Accept: "application/json" },
  });
  if (res.ok) {
    const data = await res.json();
    const list = data.results || data;
    wallets = list.map((w) => ({
      id: w.id,
      name: w.name,
      description: w.description || "",
      amount: parseFloat(w.balance || 0),
      type: WALLET_TYPE_MAP[w.name] || "cash",
      created_at: w.created_at,
      updated_at: w.updated_at,
    }));
  }
} catch (_) {}

const selectedWallet = wallets.length > 0 ?
  wallets[0] : { id: null, name: "No wallets", description: "", amount: 0, type: "cash" };
const icon = selectedWallet.type ?
  walletType[selectedWallet.type as keyof typeof walletType]?.icon : IconCash;

let transactions = [];
try {
  const txRes = await fetch("http://127.0.0.1:8000/api/expenses/transactions/?limit=100", {
    headers: { Accept: "application/json" },
  });
  if (txRes.ok) {
    const txData = await txRes.json();
    const rawList = txData.results || txData;

    let filteredList = rawList;
    if (selectedWallet && selectedWallet.id) {
      filteredList = rawList.filter((t) => String(t.wallet) === String(selectedWallet.id) || t.wallet_name === selectedWallet.name);
    }

    const list = filteredList.slice().sort((a, b) => {
      const dateDiff = new Date(b.transaction_date).getTime() - new Date(a.transaction_date).getTime();
      if (dateDiff !== 0) return dateDiff;
      return (b.id || 0) - (a.id || 0);
    });
    
    transactions = list.map((t) => ({
      id: t.id,
      amount: t.amount,
      wallet_name: t.wallet_name,
      category: t.category,
      category_label: t.BIR_label || t.category,
      transaction_type: t.transaction_type,
      note: t.note || "--",
      user_name: t.user_name || "User 1",
      transaction_date: t.transaction_date,
    }));
  }
} catch (_) {}

---

<Layout>
    <div class="wallets-page">
        <div class="page-inner">
            <div class="balancecard">
                <div class="wallet-button-group">
                    <button
                        id="edit-wallet"
                        class="wallet-button"
                        type="button"
                        aria-label="Edit wallet"
                        data-modal="edit-wallet-modal"
                    >
                        <span set:html={IconEdit}></span>
                        <span>Edit</span>
                    </button>

                    <button
                        id="delete-wallet"
                        class="wallet-button danger"
                        type="button"
                        aria-label="Delete wallet"
                        data-modal="delete-wallet-modal"
                    >
                        <span set:html={IconDelete}></span>
                        <span>Delete</span>
                    </button>
                </div>
                <div class="balancecard-header">
                    <div
                        id="wallet-icon"
                        class="balancecard-icon-wrapper"
                        set:html={icon}
                    ></div>
                    <div
                        id="wallet-name"
                        class="balancecard-heading"
                    >
                        {selectedWallet.name}
                    </div>
                </div>

                <div
                    id="balance-amount"
                    class="balancecard-amount truncate"
                    data-balance={selectedWallet.amount}
                >
                    {`₱${selectedWallet.amount.toLocaleString("en-PH", {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    })}`}
                </div>

                <div
                    id="wallet-description"
                    class="wallet-description"
                >
                    {selectedWallet.description}
                </div>

                <div class="balancecard-action-buttons">
                    <button class="card-button" data-modal="add-funds-modal"><span set:html={IconAddFunds}></span>Add Funds</button>
                    <button class="card-button" id="spend-funds-button"><span set:html={IconSpendFunds}></span>Spend Funds</button>
                    <button class="card-button" data-modal="move-funds-modal"><span set:html={IconMoveFunds}></span>Move Funds</button>
                </div>
            </div>
            <div class="left-container">
                <div class="button-group flex justify-between items-center">
                    <p class="[font-family:var(--display-headings-font)] font-bold">WALLETS</p>
                    <button class="p-2 px-5 bg-[var(--primary-orange)] rounded-2xl text-white" data-modal="add-wallet-modal">
                        Add Wallet
                    </button>
                </div>
                    <div class="h-100 overflow-y-auto overflow-x-hidden scrollbar-thin">
                        <div class="wallets-group">
                        {
                            wallets.map((wallet) => (
                                <div
                                    class="wallet-item"
                                    data-id={wallet.id}
                                    data-name={wallet.name}
                                    data-description={wallet.description}
                                    data-amount={wallet.amount}
                                    data-type={wallet.type}
                                >
                                    <WalletCard
                                        name={wallet.name}
                                        amount={`₱${wallet.amount.toLocaleString("en-PH", {
                                            minimumFractionDigits: 2,
                                            maximumFractionDigits: 2
                                        })}`}
                                        type={wallet.type as "cash" | "e-wallet" | "bank"}
                                    />
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
            <div class="transaction-history">
                <div class="transaction-headings blue">
                    <div class="transaction-top-row">
                        <div>
                            <p>RECENT TRANSACTIONS</p>
                            <p id="transaction-filter-label">Showing results for All Transactions</p>
                        </div>
                        <div class="filtergroup">
                            <button class="filter-chip active" data-filter="all">All</button>
                            <button class="filter-chip" data-filter="added">Added Funds</button>
                            <button class="filter-chip" data-filter="spent">Spent Funds</button>
                        </div>
                    </div>
                    <div class="transactionlabels">
                        <p>AMOUNT</p>
                        <p>WALLET</p>
                        <p>CATEGORY</p>
                        <p>NOTE</p>
                        <p>USER</p>
                        <p>DATE</p>
                    </div>
                </div>
                <div class="transaction-history-scrollable">
                    <div class="transaction-history-slots" id="recent-transactions">
                        {transactions.length === 0 ? (
                            <div class="transactionrow">
                                <p colspan="6" style="text-align:center;opacity:0.5">No transactions yet</p>
                            </div>
                        ) : (
                            transactions.map((t) => {
                                const isAdd = t.transaction_type === "add funds";
                                const isSpend = t.transaction_type === "spend funds";
                                const color = isAdd ? "#2ecc71" : (isSpend ? "#e74c3c" : "#f39c12");
                                const sign = isAdd ? "+" : (isSpend ? "-" : "~");
                                const amt = Number(t.amount).toLocaleString("en-PH", {minimumFractionDigits:2});
                                return <div class="transactionrow">
                                    <p style={`color:${color};font-weight:600`}>{sign}₱{amt}</p>
                                    <p>{t.wallet_name}</p>
                                    <p>{t.category_label || t.category}</p>
                                    <p>{t.note}</p>
                                    <p>{t.user_name}</p>
                                    <p>{formatTransactionDate(t.transaction_date)}</p>
                                </div>;
                            })
                        )}
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>


<!-- Modals -->
    <div id="add-wallet-modal" class="modal-overlay" aria-hidden="true">
        <div class="modal modal--orange" role="dialog" aria-modal="true" aria-labelledby="add-wallet-title">
            <div class="modal-header">
                <div class="modal-header-left">
                    <span class="modal-header-icon"><Fragment set:html={IconAddFunds} /></span>
                    <h2 id="add-wallet-title">Add Wallet</h2>
                </div>
                <button class="modal-close" aria-label="Close modal">✕</button>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label for="wallet-name-input">WALLET NAME</label>
                    <div class="input-icon-wrapper">
                        <input id="wallet-name-input" name="name" type="text" placeholder="e.g. Petty Cash" />
                    </div>
                </div>

                <div class="form-group">
                    <label for="wallet-type-input">WALLET TYPE</label>
                    <div class="input-icon-wrapper">
                        <select id="wallet-type-input" name="type">
                            <option value="" disabled selected>Select Type</option>
                            <option value="cash">Cash</option>
                            <option value="e-wallet">E-Wallet</option>
                            <option value="bank">Bank</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="wallet-description-input">DESCRIPTION</label>
                    <textarea id="wallet-description-input" name="description" rows="3" placeholder="What is this wallet used for?"></textarea>
                </div>

                <div class="system-note">
                    <span class="system-note-icon"><Fragment set:html={IconInfo} /></span>
                    <p>New wallets start with a balance of <strong>₱0.00</strong>. You can add or move funds into this wallet after it's created.</p>
                </div>

            </div>

            <div class="modal-footer modal-footer--stack">
                <div class="modal-footer-row">
                    <button type="button" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary--navy" id="add-wallet-submit">Create Wallet</button>
                </div>
            </div>
        </div>
    </div>
    <div id="add-funds-modal" class="modal-overlay" aria-hidden="true">
        <div class="modal modal--navy" role="dialog" aria-modal="true" aria-labelledby="add-funds-title">
            <div class="modal-header">
                <div class="modal-header-left">
                    <span class="modal-header-icon"><Fragment set:html={IconCashDown} /></span>
                    <h2 id="add-funds-title">Add Funds</h2>
                </div>
                <button class="modal-close" aria-label="Close modal">✕</button>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label for="fund-amount">FUND AMOUNT</label>
                    <div class="input-icon-wrapper">
                        <span class="input-icon"><Fragment set:html={IconPeso} /></span>
                        <input id="fund-amount" name="amount" type="number" min="0" step="1" placeholder="Enter Amount" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="fund-category">CATEGORY</label>
                        <div class="input-icon-wrapper">
                            <span class="input-icon"><Fragment set:html={IconCashDown} /></span>
                            <select id="fund-category" name="category">
                                <option value="" disabled selected>Loading categories...</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="fund-wallet">DESTINATION WALLET</label>
                        <div class="input-icon-wrapper">
                            <span class="input-icon"><Fragment set:html={IconWallet} /></span>
                            <select id="fund-wallet" name="wallet">
                                <option value="" disabled selected>Select Wallet</option>
                                {
                                    wallets.map((wallet) => (
                                        <option value={wallet.id}>
                                            {wallet.name}
                                        </option>
                                    ))
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="advanced-toggle-wrapper">
                    <button type="button" class="advanced-toggle" id="advanced-toggle-add">
                        Advanced <span class="advanced-arrow" set:html={IconChevronDown}></span>
                    </button>
                    <div class="advanced-divider"></div>
                </div>

                <div class="advanced-fields" id="advanced-fields-add">

                    <div class="form-group">
                        <label for="fund-note">NOTE</label>
                        <textarea id="fund-note" name="note" rows="3" placeholder="Add a note about this transaction..."></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="fund-date">DATE</label>
                            <div class="input-icon-wrapper">
                                <input id="fund-date" name="date" type="date" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="fund-attachment-input">ATTACHMENT</label>
                            <label class="file-upload-wrapper" for="fund-attachment-input">
                                <span class="placeholder-text" id="fund-attachment-filename">Select files</span>
                                <span class="input-icon-right"><Fragment set:html={IconAttachment} /></span>
                            </label>
                            <input type="file" id="fund-attachment-input" name="attachment" accept="image/*" style="display: none;" />
                        </div>
                    </div>

                </div>
            </div>

            <div class="modal-footer modal-footer--stack">
                <button type="button" class="btn-save-another" id="add-funds-save-another">Save and Add Another</button>
                <div class="modal-footer-row">
                    <button type="button" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary btn-primary--navy" id="add-funds-submit">Add Funds</button>
                </div>
            </div>
        </div>
    </div>
    <div id="move-funds-modal" class="modal-overlay" aria-hidden="true">
        <div class="modal modal--grey" role="dialog" aria-modal="true" aria-labelledby="move-funds-title">
            <div class="modal-header">
                <div class="modal-header-left">
                    <span class="modal-header-icon"><Fragment set:html={IconMoveFunds} /></span>
                    <h2 id="move-funds-title">Move Funds</h2>
                </div>
                <button class="modal-close" aria-label="Close modal">✕</button>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label for="move-amount">FUND AMOUNT</label>
                    <div class="input-icon-wrapper">
                        <span class="input-icon"><Fragment set:html={IconPeso} /></span>
                        <input id="move-amount" name="amount" type="number" min="0" step="1" placeholder="Enter Amount" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="move-source">SOURCE WALLET</label>
                        <div class="input-icon-wrapper">
                            <span class="input-icon"><Fragment set:html={IconWallet} /></span>
                            <select id="move-source" name="source_wallet">
                                <option value="" disabled selected>Select Wallet</option>
                                {wallets.map((wallet) => (
                                    <option value={wallet.id}>{wallet.name}</option>
                                ))}
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="move-destination">DESTINATION WALLET</label>
                        <div class="input-icon-wrapper">
                            <span class="input-icon"><Fragment set:html={IconWallet} /></span>
                            <select id="move-destination" name="destination_wallet">
                                <option value="" disabled selected>Select Wallet</option>
                                {wallets.map((wallet) => (
                                    <option value={wallet.id}>{wallet.name}</option>
                                ))}
                            </select>
                        </div>
                    </div>
                </div>

                <div class="advanced-toggle-wrapper">
                    <button type="button" class="advanced-toggle" id="advanced-toggle-move">
                        Advanced <span class="advanced-arrow" set:html={IconChevronDown}></span>
                    </button>
                    <div class="advanced-divider"></div>
                </div>

                <div class="advanced-fields" id="advanced-fields-move">
                    <div class="form-group">
                        <label for="move-note">NOTE</label>
                        <textarea id="move-note" name="note" rows="3" placeholder="Add a note about this transaction..."></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="move-date">DATE</label>
                            <div class="input-icon-wrapper">
                                <input id="move-date" name="date" type="date" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="move-attachment-input">ATTACHMENT</label>
                            <label class="file-upload-wrapper" for="move-attachment-input">
                                <span class="placeholder-text" id="move-attachment-filename">Select files</span>
                                <span class="input-icon-right"><Fragment set:html={IconAttachment} /></span>
                            </label>
                            <input type="file" id="move-attachment-input" name="attachment" accept="image/*" style="display: none;" />
                        </div>
                    </div>
                </div>

            </div>

            <div class="modal-footer modal-footer--stack">
                <button type="button" class="btn-save-another btn-save-another--grey" id="move-funds-save-another">Save and Move Another</button>
                <div class="modal-footer-row">
                    <button type="button" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary--move" id="move-funds-submit">Move Funds</button>
                </div>
            </div>
        </div>
    </div>
    <div id="edit-wallet-modal" class="modal-overlay" aria-hidden="true">
        <div class="modal modal--orange" role="dialog" aria-modal="true" aria-labelledby="edit-wallet-title">
            <div class="modal-header">
                <div class="modal-header-left">
                    <span class="modal-header-icon"><Fragment set:html={IconEdit} /></span>
                    <h2 id="edit-wallet-title">Edit Wallet</h2>
                </div>
                <button class="modal-close" aria-label="Close modal">✕</button>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label for="edit-wallet-name-input">WALLET NAME</label>
                    <div class="input-icon-wrapper">
                        <input id="edit-wallet-name-input" name="name" type="text" placeholder="e.g. Petty Cash" />
                    </div>
                </div>

                <div class="form-group">
                    <label for="edit-wallet-type-input">WALLET TYPE</label>
                    <div class="input-icon-wrapper">
                        <select id="edit-wallet-type-input" name="type">
                            <option value="cash">Cash</option>
                            <option value="e-wallet">E-Wallet</option>
                            <option value="bank">Bank</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="edit-wallet-description-input">DESCRIPTION</label>
                    <textarea id="edit-wallet-description-input" name="description" rows="3" placeholder="What is this wallet used for?"></textarea>
                </div>

            </div>

            <div class="modal-footer modal-footer--stack">
                <div class="modal-footer-row">
                    <button type="button" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary--navy" id="edit-wallet-submit">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <div id="delete-wallet-modal" class="modal-overlay" aria-hidden="true">
        <div class="modal modal--danger" role="dialog" aria-modal="true" aria-labelledby="delete-wallet-title">
            <div class="modal-header">
                <div class="modal-header-left">
                    <span class="modal-header-icon"><Fragment set:html={IconDelete} /></span>
                    <h2 id="delete-wallet-title">Delete Wallet</h2>
                </div>
                <button class="modal-close" aria-label="Close modal">✕</button>
            </div>

            <div class="modal-body">
                <p class="delete-warning-text">Are you sure you want to delete this wallet? This action cannot be undone.</p>

                <div class="delete-wallet-summary">
                    <span class="delete-wallet-summary-name" id="delete-wallet-name">Wallet Name</span>
                    <span class="delete-wallet-summary-amount" id="delete-wallet-amount">₱0.00</span>
                </div>

                <div class="system-note system-note--danger">
                    <span class="system-note-icon"><Fragment set:html={IconInfo} /></span>
                    <p>Deleting this wallet will permanently remove its transaction history.</p>
                </div>
            </div>

            <div class="modal-footer modal-footer--stack">
                <div class="modal-footer-row">
                    <button type="button" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary--danger" id="delete-wallet-submit">Delete Wallet</button>
                </div>
            </div>
        </div>
    </div>

<AddExpenseModal />

<script>
  document.addEventListener('astro:page-load', () => {
    const openBtn = document.getElementById('spend-funds-button');
    const modalOutside = document.getElementById('addExpenseModal');
    if (openBtn && modalOutside) {
      openBtn.addEventListener('click', () => {
        const currentWallet = window.currentWallet;
        if (currentWallet && currentWallet.id) {
          const select = modalOutside.querySelector('select[name="wallet"]') || modalOutside.querySelector('select');
          if (select) {
            const optionExists = Array.from(select.options).some(opt => opt.value === String(currentWallet.id));
            if (optionExists) {
              select.value = currentWallet.id;
            }
          }
        }
        const dateInput = modalOutside.querySelector('input[type="date"]');
        if (dateInput) {
          const today = new Date().toISOString().split('T')[0];
          dateInput.value = today;
        }
        modalOutside.showModal();
      });
    }
    
  });
</script>

<style is:global>
    .page-inner {
        --balancecard-width: 680px;
        --heading-text: 1.75rem;
        --label-text: 0.8125rem;
        --small-text: 0.875rem;
    }

    .wallets-page {
        display: flex;
        justify-content: center;
    }

    .page-inner {
        width: 100%;
        max-width: 1600px;
        display: grid;
        grid-template-columns: var(--balancecard-width) 1fr;
        grid-template-rows: auto auto;
        align-items: start;
        gap: var(--space-lg);
    }

    /* ---------- Balance card ---------- */
    .balancecard {
        position: relative;
        grid-column: 1;
        grid-row: 1;
        background: var(--orange-gradient);
        border-radius: var(--radius-lg);
        padding: var(--space-lg);
        color: #ffffff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: var(--space-md);
        box-shadow: var(--default-shadow);
        min-width: 0;
        transition: transform .25s ease, box-shadow .25s ease;
        height: 100%;
    }

    .balancecard:hover {
        transform: translateY(-3px);
        box-shadow: 0 18px 36px rgba(0,0,0,.16);
    }

    .balancecard-header {
        display: flex;
        align-items: center;
        gap: var(--space-md);
    }

    .balancecard-icon-wrapper {
        width: 5rem;
        height: 5rem;
        flex-shrink: 0;
        border-radius: var(--radius-md);
        background-color: rgba(255,255,255,.3);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .balancecard-icon-wrapper :global(svg) {
        width: 3rem;
        height: 3rem;
        stroke: #ffffff;
    }

    .balancecard-heading {
        font-family: var(--display-headings-font);
        font-size: var(--heading-text);
        font-weight: 700;
    }

