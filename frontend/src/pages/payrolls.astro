</style>

<script>
    const BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api';
    const token = localStorage.getItem('token') || localStorage.getItem('auth_token');

    function formatLocalDate(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
    }

    // mutable state — single source of truth for the selected period
    let periodStart = '';
    let periodEnd = '';

    function getDefaultPeriod() {
        const now = new Date();
        const start = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-01`;
        const end = formatLocalDate(now);
        return { start, end };
    }

    function formatPeso(amount) {
        return "₱" + Number(amount).toLocaleString("en-PH", {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    function updateOverviewHeading(period, label) {
        const headingLabel = document.getElementById('heading-period-label');
        if (!headingLabel) return;

        if (period === 'custom') {
            const from = document.getElementById('period-from');
            const to = document.getElementById('period-to');
            if (from && to && from.value && to.value) {
                const fromDate = new Date(from.value).toLocaleDateString('en-PH', {
                    month: 'short', day: 'numeric', year: 'numeric'
                });
                const toDate = new Date(to.value).toLocaleDateString('en-PH', {
                    month: 'short', day: 'numeric', year: 'numeric'
                });
                headingLabel.textContent = ` ${fromDate} – ${toDate}`;
            } else {
                headingLabel.textContent = ' Custom Range';
            }
        } else {
            headingLabel.textContent = ` This ${label}`;
        }
    }

    async function apiFetch(path) {
        const headers = {};
        if (token) headers['Authorization'] = `Token ${token}`;
        const res = await fetch(`${BASE}${path}`, { headers });
        if (!res.ok) throw new Error(`${path} failed with status ${res.status}`);
        return res.json();
    }

    function renderRows(employees) {
        if (employees.length === 0) {
            return '<div class="state-text">No employees found for this period.</div>';
        }

        return employees.map(emp => {
            const isPaid = emp.payment_status === 'paid';
            const rate = emp.payment_type === 'hourly'
                ? Number(emp.hourly_rate || 0)
                : Number(emp.monthly_salary || 0);
            const rateText = emp.payment_type === 'hourly'
                ? `${formatPeso(rate)}/hr`
                : emp.payment_type === 'monthly'
                    ? `${formatPeso(rate)}/mo`
                    : '—';
            const grossPay = Number(emp.gross_pay || 0);
            const remaining = Number(emp.remaining_gross || 0);
            const name = emp.full_name || emp.name || `Employee ${emp.id}`;
            const position = emp.position || '—';

            return `
                <div
                    class="transactionrow"
                    data-status="${isPaid ? 'paid' : 'unpaid'}"
                    data-employee-id="${emp.id}"
                    data-employee="${name}"
                    data-position="${position}"
                    data-rate="${rate}"
                    data-gross="${grossPay}"
                    data-remaining="${remaining}"
                >
                    <p>${name}</p>
                    <p>${position}</p>
                    <p>${rateText}</p>
                    <p>${formatPeso(grossPay)}</p>
                    <p>${isPaid ? '₱0.00' : formatPeso(remaining)}</p>
                    <p><span class="status-badge ${isPaid ? 'paid' : 'unpaid'}">${isPaid ? 'Paid' : 'Unpaid'}</span></p>
                    <button class="pay-btn" data-modal="pay-employee-modal" ${isPaid ? 'disabled' : ''}>
                        ${isPaid ? 'Paid' : 'Pay'}
                    </button>
                </div>
            `;
        }).join('');
    }

    function attachFilters() {
        const chips = document.querySelectorAll('.filtergroup .filter-chip[data-filter]');
        const subLabel = document.getElementById('emp-count');

        chips.forEach(chip => {
            chip.addEventListener('click', () => {
                chips.forEach(c => c.classList.remove('active'));
                chip.classList.add('active');

                const filter = chip.dataset.filter;
                const rows = document.querySelectorAll('.transactionrow');

                rows.forEach(row => {
                    const match = filter === 'all' || row.dataset.status === filter;
                    row.classList.toggle('hidden', !match);
                });

                const visibleCount = [...rows].filter(r => !r.classList.contains('hidden')).length;
                if (subLabel) {
                    subLabel.textContent = `Showing ${visibleCount} ${filter === 'all' ? '' : filter + ' '}employees`;
                }
            });
        });
    }

    // Pay button + modal wiring — re-attached after every table re-render
    // since the row elements (and their data-* attributes) are recreated.
    function attachPayButtons() {
        document.querySelectorAll('[data-modal]').forEach((trigger) => {
            trigger.addEventListener('click', () => {
                const modal = document.getElementById(trigger.dataset.modal);
                if (!modal) return;

                if (modal.id === 'pay-employee-modal') {
                    const row = trigger.closest('.transactionrow');
                    if (row) {
                        const employee = row.dataset.employee || '';
                        const position = row.dataset.position || '';
                        const rate = parseFloat(row.dataset.rate || '0');
                        const remaining = parseFloat(row.dataset.remaining || '0');  // ← Use remaining
                        const employeeId = row.dataset.employeeId || '';

                        const nameEl = document.getElementById('pay-employee-name');
                        const posEl = document.getElementById('pay-employee-position');
                        const paymentEl = document.getElementById('pay-employee-payment');
                        const periodEl = document.getElementById('pay-employee-period');
                        const shiftsEl = document.getElementById('pay-employee-shifts');
                        const rateEl = document.getElementById('pay-employee-rate');
                        const grossInput = document.getElementById('pay-gross');
                        const bonusInput = document.getElementById('pay-bonus');
                        const overtimeInput = document.getElementById('pay-overtime');
                        const deductionInput = document.getElementById('pay-deduction');
                        const confirmBtn = document.getElementById('pay-employee-confirm');

                        if (nameEl) nameEl.textContent = employee;
                        if (posEl) posEl.textContent = position;
                        if (paymentEl) paymentEl.textContent = formatPeso(remaining);  // ← Use remaining
                        if (periodEl) periodEl.textContent = `${periodStart} – ${periodEnd}`;
                        if (shiftsEl) shiftsEl.textContent = rate > 0 ? String(Math.round(remaining / rate)) : '—';
                        if (rateEl) rateEl.textContent = formatPeso(rate);

                        if (grossInput) grossInput.value = formatPeso(remaining);  // ← Use remaining
                        if (bonusInput) bonusInput.value = "0.00";
                        if (overtimeInput) overtimeInput.value = "0.00";
                        if (deductionInput) deductionInput.value = "0.00";
                        if (confirmBtn) confirmBtn.dataset.employeeId = employeeId;

                        recalcNetPay();
                    }
                }

                modal.classList.add('open');
                modal.setAttribute('aria-hidden', 'false');
            });
        });
    }

    function recalcNetPay() {
        const gross = parseFloat(document.getElementById('pay-gross')?.value.replace(/[₱,]/g, '') || '0');
        const bonus = parseFloat(document.getElementById('pay-bonus')?.value || '0');
        const overtime = parseFloat(document.getElementById('pay-overtime')?.value || '0');
        const deduction = parseFloat(document.getElementById('pay-deduction')?.value || '0');

        const net = gross + bonus + overtime - deduction;
        const netEl = document.getElementById('pay-netpay');
        if (netEl) netEl.textContent = formatPeso(net);
    }

    function closeModal(modal) {
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
    }

    async function payEmployee() {
        const confirmBtn = document.getElementById('pay-employee-confirm');
        const employeeId = confirmBtn?.dataset.employeeId;
        const wallet = document.getElementById('pay-source-wallet');
        const note = document.getElementById('pay-note')?.value || '';
        const bonus = parseFloat(document.getElementById('pay-bonus')?.value || '0');
        const overtime = parseFloat(document.getElementById('pay-overtime')?.value || '0');
        const deduction = parseFloat(document.getElementById('pay-deduction')?.value || '0');

        if (!wallet?.value) {
            alert('Please select a source wallet.');
            return;
        }

        try {
            const res = await fetch(`${BASE}/payroll/employees/${employeeId}/pay/`, {
                method: "POST",
                headers: {
                    Authorization: `Token ${token}`,
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    wallet_id: wallet.value,
                    bonus,
                    overtime,
                    deduction,
                    note,
                    period_start: periodStart,
                    period_end: periodEnd
                })
            });

            if (!res.ok) {
                const error = await res.json().catch(() => ({}));
                throw new Error(error.error || 'Payment failed.');
            }

            const modal = document.getElementById('pay-employee-modal');
            if (modal) closeModal(modal);

            await loadPayroll();
        } catch (err) {
            console.error(err);
            alert(err.message);
        }
    }

    async function syncDTR() {
        try {
            await fetch(`${BASE}/payroll/workers/sync/`, {
                method: "POST",
                headers: { Authorization: `Token ${token}` }
            });

            await fetch(`${BASE}/payroll/timesheets/sync/`, {
                method: "POST",
                headers: {
                    Authorization: `Token ${token}`,
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ period_start: periodStart, period_end: periodEnd })
            });

            alert("DTR synced successfully.");
        } catch (err) {
            console.error(err);
            alert("Sync failed.");
        }
    }

    async function generatePayroll() {
        try {
            const res = await fetch(`${BASE}/payroll/runs/build/`, {
                method: "POST",
                headers: {
                    Authorization: `Token ${token}`,
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ period_start: periodStart, period_end: periodEnd })
            });

            if (!res.ok) {
                const error = await res.json();
                throw new Error(error.error);
            }

            await loadPayroll();
            alert("Payroll generated.");
        } catch (err) {
            console.error(err);
            alert(err.message);
        }
    }

    async function loadPayroll() {
        const tableBody = document.getElementById("table-body");
        const empCount = document.getElementById("emp-count");

        if (!token) {
            tableBody.innerHTML = '<div class="state-text error-text">Not logged in.</div>';
            empCount.textContent = "Unable to load data";
            return;
        }

        tableBody.innerHTML = '<div class="state-text">Loading payroll...</div>';

        try {
            const employees = await apiFetch(`/payroll/employees/?period_start=${periodStart}&period_end=${periodEnd}`);

            // ✅ Calculate total payroll from ALL shifts (gross_pay), not just remaining
            const totalPayroll = employees.reduce((sum, e) => sum + Number(e.gross_pay || 0), 0);
            const totalEmployees = employees.length;
            const paidEmployees = employees.filter(e => e.payment_status === 'paid').length;
            const unpaidEmployees = totalEmployees - paidEmployees;

            document.getElementById("stat-total").textContent = formatPeso(totalPayroll);
            document.getElementById("stat-emp").textContent = totalEmployees;
            document.getElementById("stat-paid").textContent = paidEmployees;
            document.getElementById("stat-unpaid").textContent = unpaidEmployees;

            empCount.textContent = `Showing ${employees.length} employees`;
            tableBody.innerHTML = renderRows(employees);

            attachPayButtons();
            const activeChip = document.querySelector('.filtergroup .filter-chip.active[data-filter]');
            if (activeChip && activeChip.dataset.filter !== 'all') {
                const filter = activeChip.dataset.filter;
                const rows = document.querySelectorAll('.transactionrow');
                rows.forEach(row => {
                    row.classList.toggle('hidden', row.dataset.status !== filter);
                });
                const visibleCount = [...rows].filter(r => !r.classList.contains('hidden')).length;
                empCount.textContent = `Showing ${visibleCount} ${filter} employees`;
            }
        } catch (err) {
            console.error(err);
            tableBody.innerHTML = `<div class="state-text error-text">${err.message}</div>`;
        }
    }

    function init() {
        const defaults = getDefaultPeriod();
        periodStart = defaults.start;
        periodEnd = defaults.end;

        const fromInput = document.getElementById('period-from');
        const toInput = document.getElementById('period-to');
        if (fromInput) fromInput.value = periodStart;
        if (toInput) toInput.value = periodEnd;

        updateOverviewHeading('month', 'Month');
        loadPayroll();

        // Filter chips and DTR/generate buttons — only bound once.
        attachFilters();
        document.getElementById("sync-btn")?.addEventListener("click", syncDTR);
        document.getElementById("generate-btn")?.addEventListener("click", generatePayroll);

        // Period dropdown
        const periodDropdown = document.getElementById('period-dropdown');
        const periodTrigger = document.getElementById('period-trigger');
        const periodTriggerLabel = document.getElementById('period-trigger-label');
        const periodOptions = document.querySelectorAll('.period-option');
        const customDateFields = document.getElementById('custom-date-fields');

        periodTrigger?.addEventListener('click', (e) => {
            e.stopPropagation();
            periodDropdown?.classList.toggle('open');
        });

        document.addEventListener('click', (e) => {
            if (periodDropdown && !periodDropdown.contains(e.target)) {
                periodDropdown.classList.remove('open');
            }
        });

        periodOptions.forEach((option) => {
            option.addEventListener('click', () => {
                periodOptions.forEach((o) => o.classList.remove('active'));
                option.classList.add('active');

                const period = option.dataset.period || '';
                const label = option.textContent?.trim() || '';

                if (periodTriggerLabel) {
                    periodTriggerLabel.textContent = period === 'custom' ? 'Custom' : ` This ${label}`;
                }

                updateOverviewHeading(period, label);

                if (period === 'custom') {
                    customDateFields?.classList.add('visible');
                } else {
                    customDateFields?.classList.remove('visible');

                    const now = new Date();
                    let start, end;
                    switch (period) {
                        case 'week':
                            start = new Date(now);
                            start.setDate(now.getDate() - 7);
                            end = now;
                            break;
                        case 'month':
                            start = new Date(now.getFullYear(), now.getMonth(), 1);
                            end = now;
                            break;
                        case 'quarter':
                            const quarterMonth = Math.floor(now.getMonth() / 3) * 3;
                            start = new Date(now.getFullYear(), quarterMonth, 1);
                            end = now;
                            break;
                        case 'year':
                            start = new Date(now.getFullYear(), 0, 1);
                            end = now;
                            break;
                        default:
                            return;
                    }
                    periodStart = formatLocalDate(start);
                    periodEnd = formatLocalDate(end);
                    if (fromInput) fromInput.value = periodStart;
                    if (toInput) toInput.value = periodEnd;
                    loadPayroll();
                }

                periodDropdown?.classList.remove('open');
            });
        });

        fromInput?.addEventListener('change', () => {
            if (!fromInput.value) return;
            if (toInput?.value && fromInput.value > toInput.value) {
                alert('Start date cannot be after end date.');
                fromInput.value = periodStart;
                return;
            }
            periodStart = fromInput.value;
            updateOverviewHeading('custom', 'Custom');
            loadPayroll();
        });

        toInput?.addEventListener('change', () => {
            if (!toInput.value) return;
            if (fromInput?.value && toInput.value < fromInput.value) {
                alert('End date cannot be before start date.');
                toInput.value = periodEnd;
                return;
            }
            periodEnd = toInput.value;
            updateOverviewHeading('custom', 'Custom');
            loadPayroll();
        });

        // Modal close handlers
        document.addEventListener('keydown', (e) => {
            if (e.key !== 'Escape') return;
            document.querySelectorAll('.modal-overlay.open').forEach(closeModal);
        });

        document.querySelectorAll('.modal-overlay').forEach((modal) => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal(modal);
            });
            modal.querySelector('.modal-close')?.addEventListener('click', () => closeModal(modal));
            modal.querySelector('.btn-secondary')?.addEventListener('click', () => closeModal(modal));
        });

        // Advanced toggle
        document.querySelectorAll('.advanced-toggle').forEach((btn) => {
            btn.addEventListener('click', () => {
                const targetId = btn.id.replace('advanced-toggle', 'advanced-fields');
                const fields = document.getElementById(targetId);
                if (!fields) return;
                const isOpen = fields.classList.toggle('open');
                btn.classList.toggle('open', isOpen);
            });
        });

        ['pay-bonus', 'pay-overtime', 'pay-deduction'].forEach((id) => {
            document.getElementById(id)?.addEventListener('input', recalcNetPay);
        });

        document.getElementById('pay-employee-confirm')?.addEventListener('click', payEmployee);
    }

    document.addEventListener('astro:page-load', init);
</script>