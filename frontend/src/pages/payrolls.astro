---
import Layout from '../layouts/Layout.astro';
import IconPeso from '../assets/philippine-peso.svg?raw';
import IconWallet from '../assets/wallet-icon.svg?raw';
import IconAttachment from '../assets/paperclip.svg?raw';
import IconChevronDown from '../assets/chevron-down.svg?raw';

const wallets = [
    {
        id: 1,
        name: "Petty Cash",
        description: "Daily operational cash kept on hand for small business expenses and immediate purchases. This wallet is used for quick transactions that do not require bank transfers or digital payments. Regular monitoring helps ensure accurate cash reconciliation.",
        amount: 1250.00,
        type: "cash",
        created_at: "2026-06-01T08:00:00Z",
        updated_at: "2026-06-25T14:30:00Z"
    },
    {
        id: 2,
        name: "Emergency Cash",
        description: "Reserved cash set aside for unexpected expenses or urgent financial situations. These funds should only be used when absolutely necessary to avoid disrupting regular operations. Maintaining this reserve provides additional financial security.",
        amount: 5000.00,
        type: "cash",
        created_at: "2026-06-01T08:00:00Z",
        updated_at: "2026-06-20T09:15:00Z"
    },
    {
        id: 3,
        name: "GCash",
        description: "Primary digital wallet used for mobile payments, online purchases, and fund transfers. It offers a convenient way to send and receive money instantly. Transactions are synchronized regularly to keep balances up to date.",
        amount: 2845.50,
        type: "e-wallet",
        created_at: "2026-05-10T12:00:00Z",
        updated_at: "2026-06-27T17:45:00Z"
    },
    {
        id: 4,
        name: "Maya Wallet",
        description: "Secondary e-wallet dedicated to online shopping, subscriptions, and digital services. Keeping it separate from the primary wallet makes budgeting and expense tracking easier. It also serves as a backup payment option when needed.",
        amount: 9120.00,
        type: "e-wallet",
        created_at: "2026-05-15T12:00:00Z",
        updated_at: "2026-06-26T11:20:00Z"
    },
    {
        id: 5,
        name: "UnionBank Savings",
        description: "Main savings account used for storing long-term funds and personal savings. Interest earned helps grow the balance over time while keeping funds readily accessible. Large deposits and planned withdrawals are typically managed through this account.",
        amount: 38750.81,
        type: "bank",
        created_at: "2026-04-01T09:00:00Z",
        updated_at: "2026-06-28T10:30:00Z"
    },
    {
        id: 6,
        name: "BDO Checkings",
        description: "Primary checking account used for recurring bills, supplier payments, and everyday banking transactions. It supports higher transaction volumes and provides easy access through checks and online banking. Regular activity ensures smooth financial operations.",
        amount: 112450.25,
        type: "bank",
        created_at: "2026-03-01T09:00:00Z",
        updated_at: "2026-06-29T08:15:00Z"
    }
];

---

<Layout>
    <div class="payrolls-page">
        <div class="payrolls-inner">

            <div class="heading-section blue">
                <div class="heading-top-row">
                    <h2 class="heading-title">
                        Showing Results For 
                        <span id="heading-period-label"></span>
                    </h2>
                    <div class="date-filters">
                        <div class="period-dropdown" id="period-dropdown">
                            <button type="button" class="period-trigger" id="period-trigger">
                                <span id="period-trigger-label">Select Time</span>
                                <span class="period-chevron"><Fragment set:html={IconChevronDown} /></span>
                            </button>
                            <div class="period-menu" id="period-menu">
                                <button type="button" class="period-option active" data-period="week">Week</button>
                                <button type="button" class="period-option" data-period="month">Month</button>
                                <button type="button" class="period-option" data-period="quarter">Quarter</button>
                                <button type="button" class="period-option" data-period="year">Year</button>
                                <button type="button" class="period-option" data-period="custom">Custom</button>
                            </div>
                        </div>

                        <div class="custom-date-fields" id="custom-date-fields">
                            <input type="date" class="date-input" id="period-from" value="2026-05-27" />
                            <span class="date-separator">to</span>
                            <input type="date" class="date-input" id="period-to" value="2026-05-30" />
                        </div>
                    </div>
                </div>
                <div class="heading-divider"></div>
                <div class="overviews">
                    <div class="overview-item">
                        <p class="overview-label">TOTAL PAYROLL</p>
                        <p class="overview-value">P1236821</p>
                    </div>
                    <div class="overview-item">
                        <p class="overview-label">TOTAL EMPLOYEES</p>
                        <p class="overview-value">21</p>
                    </div>
                    <div class="overview-item">
                        <p class="overview-label">PAID EMPLOYEES</p>
                        <p class="overview-value">8</p>
                    </div>
                    <div class="overview-item">
                        <p class="overview-label">UNPAID EMPLOYEES</p>
                        <p class="overview-value">13</p>
                    </div>
                </div>
            </div>

            <div class="transaction-history">
                <div class="transaction-headings orange">
                    <div class="transaction-top-row">
                        <div>
                            <p class="table-heading-title">EMPLOYEE PAYROLL</p>
                            <p class="table-heading-sub">Showing results for</p>
                        </div>
                        <div class="filtergroup">
                            <button class="filter-chip active" data-filter="all">All</button>
                            <button class="filter-chip" data-filter="Paid">Paid</button>
                            <button class="filter-chip" data-filter="Unpaid">Unpaid</button>
                        </div>
                    </div>
                    <div class="payroll-labels">
                        <p>EMPLOYEE</p>
                        <p>POSITION</p>
                        <p>SALARY RATE</p>
                        <p>REMAINING</p>
                        <p>STATUS</p>
                        <p>ACTION</p>
                    </div>
                </div>
                <div class="transaction-history-scrollable">
                    <div class="transaction-history-slots">
                        <div
                            class="transactionrow"
                            data-status="Paid"
                            data-employee="Admin User"
                            data-position="Admin Developer"
                            data-rate="1999.99"
                            data-remaining="0"
                        >
                            <p>Admin User</p>
                            <p>Admin Developer</p>
                            <p>₱1,999.99/hr</p>
                            <p>₱00.00</p>
                            <p class="status-badge paid">Paid</p>
                            <button class="pay-btn" data-modal="pay-employee-modal">Pay</button>
                        </div>
                        <div
                            class="transactionrow"
                            data-status="Unpaid"
                            data-employee="Juan Dela Cruz"
                            data-position="Cashier"
                            data-rate="80.00"
                            data-remaining="3200.00"
                        >
                            <p>Juan Dela Cruz</p>
                            <p>Cashier</p>
                            <p>₱80.00/hr</p>
                            <p>₱3,200.00</p>
                            <p class="status-badge unpaid">Unpaid</p>
                            <button class="pay-btn" data-modal="pay-employee-modal">Pay</button>
                        </div>
                        <div
                            class="transactionrow"
                            data-status="Paid"
                            data-employee="Maria Santos"
                            data-position="Supervisor"
                            data-rate="120.00"
                            data-remaining="0"
                        >
                            <p>Maria Santos</p>
                            <p>Supervisor</p>
                            <p>₱120.00/hr</p>
                            <p>₱00.00</p>
                            <p class="status-badge paid">Paid</p>
                            <button class="pay-btn" data-modal="pay-employee-modal">Pay</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <!-- Pay Employee Modal -->
    <div id="pay-employee-modal" class="modal-overlay" aria-hidden="true">
        <div class="modal modal--orange" role="dialog" aria-modal="true" aria-labelledby="pay-employee-title">
            <div class="modal-header">
                <div class="modal-header-left">
                    <span class="modal-header-icon"><Fragment set:html={IconPeso} /></span>
                    <h2 id="pay-employee-title">Pay Employee</h2>
                </div>
                <button class="modal-close" aria-label="Close modal">✕</button>
            </div>

            <div class="modal-body">

                <!-- Employee + Position -->
                <div class="form-row">
                    <div class="form-group">
                        <label>EMPLOYEE</label>
                        <p class="readonly-value" id="pay-employee-name">—</p>
                    </div>
                    <div class="form-group">
                        <label>POSITION</label>
                        <p class="readonly-value" id="pay-employee-position">—</p>
                    </div>
                </div>

                <!-- Payment total -->
                <div class="form-group">
                    <label>PAYMENT</label>
                    <p class="payment-total" id="pay-employee-payment">₱0.00</p>
                </div>

                <!-- Period / Shifts / Rate -->
                <div class="pay-meta-row">
                    <div class="pay-meta-item">
                        <label>PERIOD</label>
                        <p id="pay-employee-period">—</p>
                    </div>
                    <div class="pay-meta-item">
                        <label>SHIFTS</label>
                        <p id="pay-employee-shifts">—</p>
                    </div>
                    <div class="pay-meta-item">
                        <label>RATE</label>
                        <p id="pay-employee-rate">—</p>
                    </div>
                </div>

                <!-- Source Wallet -->
                <div class="form-group">
                    <label for="pay-source-wallet">SOURCE WALLET</label>
                    <div class="input-icon-wrapper">
                        <span class="input-icon"><Fragment set:html={IconWallet} /></span>
                        <select id="pay-source-wallet" name="source_wallet">
                            <option value="" disabled selected>Select Wallet</option>
                            {
                                wallets.map((wallet) => (
                                    <option value={wallet.id}>
                                        {wallet.name}
                                    </option>
                                ))
                            }
                        </select>
                    </div>
                </div>

                <!-- Advanced Toggle -->
                <div class="advanced-toggle-wrapper">
                    <button type="button" class="advanced-toggle open" id="advanced-toggle-pay">
                        Advanced <span class="advanced-arrow">▼</span>
                    </button>
                    <div class="advanced-divider"></div>
                </div>

                <!-- Advanced Fields (open by default, matches the screenshot) -->
                <div class="advanced-fields open" id="advanced-fields-pay">

                    <!-- Breakdown -->
                    <div class="breakdown-box">
                        <p class="breakdown-title">BREAKDOWN</p>

                        <div class="breakdown-row">
                            <label for="pay-gross">Gross Pay</label>
                            <input id="pay-gross" name="gross_pay" type="text" readonly />
                        </div>

                        <div class="breakdown-row">
                            <label for="pay-bonus">Bonus</label>
                            <input id="pay-bonus" name="bonus" type="number" min="0" step="0.01" value="0.00" />
                        </div>

                        <div class="breakdown-row">
                            <label for="pay-overtime">Overtime</label>
                            <input id="pay-overtime" name="overtime" type="number" min="0" step="0.01" value="0.00" />
                        </div>

                        <p class="breakdown-subtitle">DEDUCTIONS</p>

                        <div class="breakdown-row">
                            <label for="pay-deduction">Deduction</label>
                            <input id="pay-deduction" name="deduction" type="number" min="0" step="0.01" value="0.00" />
                        </div>

                        <div class="breakdown-netpay">
                            <span>NET PAY</span>
                            <span id="pay-netpay">₱0.00</span>
                        </div>
                    </div>

                    <!-- Note -->
                    <div class="form-group">
                        <label for="pay-note">NOTE</label>
                        <textarea id="pay-note" name="note" rows="3" placeholder="Add a note about this transaction..."></textarea>
                    </div>

                    <!-- Date + Attachment -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="pay-date">DATE</label>
                            <div class="input-icon-wrapper">
                                <input id="pay-date" name="date" type="date" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="pay-attachment">ATTACHMENT</label>
                            <div class="input-icon-wrapper">
                                <input id="pay-attachment" name="attachment" type="text" placeholder="Select files" />
                                <span class="input-icon-right"><Fragment set:html={IconAttachment} /></span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="modal-footer modal-footer--stack">
                <div class="modal-footer-row">
                    <button type="button" class="btn-secondary">Cancel</button>
                    <button type="button" class="btn-primary--navy">Pay Employee</button>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .payrolls-page {
        display: flex;
        justify-content: center;
    }

    .payrolls-inner {
        width: 100%;
        max-width: 1600px;
        display: flex;
        flex-direction: column;
        gap: var(--space-lg);
    }

    .heading-section {
        color: #ffffff;
        border-radius: var(--radius-lg);
        padding: var(--space-lg);
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .heading-top-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: var(--space-md);
    }

    .heading-title {
        font-family: var(--display-headings-font);
        font-size: 1.5rem;
        font-weight: 700;
    }

    .date-filters {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        flex-wrap: wrap;
    }

    .date-separator {
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        opacity: 0.7;
    }

    .period-dropdown {
        position: relative;
    }

    .period-trigger {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.1);
        border: none;
        border-radius: var(--radius-md);
        padding: var(--space-sm) var(--space-md);
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        color: #ffffff;
        cursor: pointer;
        transition: background-color 150ms ease;
    }

    .period-trigger:hover {
        background: rgba(255, 255, 255, 0.18);
    }

    .period-chevron {
        display: flex;
        align-items: center;
        width: 14px;
        height: 14px;
        transition: transform 0.2s ease;
    }

    .period-chevron :global(svg) {
        width: 14px;
        height: 14px;
        stroke: #ffffff;
    }

    .period-dropdown.open .period-chevron {
        transform: rotate(180deg);
    }

    .period-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        background: var(--white);
        border-radius: var(--radius-md);
        box-shadow: var(--default-shadow);
        padding: 6px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 140px;
        z-index: 50;

        opacity: 0;
        transform: translateY(-6px);
        pointer-events: none;
        transition: opacity 0.15s ease, transform 0.15s ease;
    }

    .period-dropdown.open .period-menu {
        opacity: 1;
        transform: translateY(0);
        pointer-events: all;
    }

    .period-option {
        background: none;
        border: none;
        text-align: left;
        padding: 8px 10px;
        border-radius: var(--radius-sm);
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        color: var(--primary-navyblue);
        cursor: pointer;
        transition: background-color 150ms ease;
    }

    .period-option:hover {
        background: #f3f5f9;
    }

    .period-option.active {
        background: var(--primary-orange);
        color: #ffffff;
    }

    .custom-date-fields {
        display: none;
        align-items: center;
        gap: var(--space-sm);
    }

    .custom-date-fields.visible {
        display: flex;
    }

    .date-input {
        background: rgba(255, 255, 255, 0.1);
        border: none;
        border-radius: var(--radius-md);
        padding: var(--space-sm) var(--space-md);
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        color: #ffffff;
        outline: none;
        color-scheme: dark;
    }

    .date-input:focus {
        background: rgba(255, 255, 255, 0.18);
    }

    .heading-divider {
        height: 1px;
        width: 100%;
        background-color: #ffffff;
    }

    .overviews {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
    }

    .overview-item {
        padding: var(--space-sm) var(--space-lg);
        border-right: 1px solid rgba(255, 255, 255, 0.25);
    }

    .overview-item:last-child {
        border-right: none;
    }

    .overview-label {
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        opacity: 0.8;
        margin-bottom: var(--space-sm);
        letter-spacing: 0.04em;
    }

    .overview-value {
        font-family: var(--display-headings-font);
        font-size: var(--display-headings-text);
        font-weight: 700;
    }

    .transaction-history {
        background-color: var(--white);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--default-shadow);
        min-width: 0;
    }

    .transaction-headings {
        padding: var(--space-md);
        color: #ffffff;
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .transaction-top-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: var(--space-sm);
    }

    .table-heading-title {
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        font-weight: 700;
    }

    .table-heading-sub {
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        opacity: 0.8;
    }

    .filtergroup {
        display: flex;
        gap: var(--space-sm);
        align-items: center;
        flex-wrap: wrap;
    }

    .filter-chip {
        border: 2px solid #ffffff;
        border-radius: var(--radius-pill);
        padding: var(--space-sm) var(--space-md);
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        cursor: pointer;
        background: transparent;
        color: #ffffff;
        transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;
    }

    .filter-chip:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .filter-chip.active {
        background: var(--primary-orange);
        border-color: var(--primary-orange);
        color: #ffffff;
    }

    .payroll-labels {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr 1fr 120px;
        padding: 0 var(--space-lg);
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
    }

    .transaction-history-scrollable {
        min-height: 200px;
        max-height: 500px;
        overflow-y: auto;
        overflow-x: hidden;
        scrollbar-width: thin;
    }

    .transactionrow {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr 1fr 120px;
        align-items: center;
        padding: var(--space-md) var(--space-lg);
        border-bottom: 1px solid var(--light-grey);
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        transition: background-color 150ms ease;
    }

    .status-badge {
        display: flex;
        padding: 3px 10px;
        border-radius: var(--radius-pill);
        font-size: 0.8rem;
        font-weight: 600;
    }

    .status-badge.paid {
        color: #00a10d;
    }

    .status-badge.unpaid {
        color: #721e34;
    }

    .transactionrow.hidden {
        display: none;
    }

    .pay-btn {
        border: none;
        border-radius: var(--radius-md);
        padding: 8px 16px;
        background: var(--orange-gradient);
        color: white;
        font-family: var(--general-text-font);
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 150ms ease, opacity 150ms ease;
    }

    .pay-btn:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    .pay-btn:active {
        transform: translateY(0);
    
    }

    /* Modals */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);

        display: flex;
        justify-content: center;
        align-items: center;

        padding: 2rem var(--space-md);

        z-index: 1000;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
    }

    .modal-overlay.open {
        opacity: 1;
        pointer-events: all;
    }

    .modal {
        background: var(--white);
        border-radius: var(--radius-lg);
        width: 100%;
        max-width: 480px;

        max-height: 90vh;

        display: flex;
        flex-direction: column;
        overflow: hidden;

        box-shadow: 0 20px 48px rgba(0, 0, 0, 0.25);
        transform: translateY(12px);
        transition: transform 0.2s ease;
    }

    .modal-overlay.open .modal {
        transform: translateY(0);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-md) var(--space-lg);
        color: #fff;
        flex-shrink: 0;
    }

    .modal--orange .modal-header {
        background: var(--orange-gradient);
    }

    .modal-header-left {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
    }

    .modal-header-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        opacity: 0.9;
        font-weight: 700;
    }

    .modal-header h2 {
        font-family: var(--display-headings-font);
        font-size: 1.15rem;
        margin: 0;
        font-weight: 700;
    }

    .modal-close {
        background: rgba(255, 255, 255, 0.15);
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s ease;
        flex-shrink: 0;
    }

    .modal-close:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    .modal-body {
        padding: var(--space-lg);
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        overflow-y: auto;
        flex: 1;
        min-height: 0;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-group label {
        font-family: var(--general-text-font);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--primary-navyblue);
    }

    .readonly-value {
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        font-weight: 700;
        color: var(--primary-orange);
        margin: 0;
    }

    .payment-total {
        font-family: var(--display-headings-font);
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-orange);
        margin: 0;
    }

    .pay-meta-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: var(--space-md);
        background: #f3f5f9;
        border-radius: var(--radius-md);
        padding: var(--space-md);
    }

    .pay-meta-item label {
        font-size: 0.68rem;
        font-weight: 700;
