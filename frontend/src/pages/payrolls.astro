        }

        .table-heading-sub {
            font-size: 0.75rem;
        }

        .filter-chip {
            padding: 5px 10px;
            font-size: 0.7rem;
        }

        .payroll-labels,
        .transactionrow {
            grid-template-columns: 1fr 1fr 1fr;
            padding: var(--space-sm) var(--space-md);
        }

        .payroll-labels {
            font-size: 0.7rem;
        }

        .transactionrow {
            font-size: 0.75rem;
        }
    }
</style>

<script>
    function closeModal(modal: HTMLElement) {
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
    }

    document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        document.querySelectorAll<HTMLElement>('.modal-overlay.open').forEach(closeModal);
    });

    function formatPeso(amount: number) {
        return "₱" + amount.toLocaleString("en-PH", {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    document.addEventListener("astro:page-load", () => {

        const headingPeriodLabel = document.getElementById("heading-period-label") as HTMLElement;
        const periodFrom = document.getElementById("period-from") as HTMLInputElement;
        const periodTo = document.getElementById("period-to") as HTMLInputElement;

        function updateOverviewHeading(period: string, label: string) {
            if (!headingPeriodLabel) return;

            if (period === "custom") {
                if (periodFrom.value && periodTo.value) {
                    const from = new Date(periodFrom.value).toLocaleDateString("en-PH", {
                        month: "short",
                        day: "numeric",
                        year: "numeric",
                    });

                    const to = new Date(periodTo.value).toLocaleDateString("en-PH", {
                        month: "short",
                        day: "numeric",
                        year: "numeric",
                    });

                    headingPeriodLabel.textContent = ` ${from} – ${to}`;
                } else {
                    headingPeriodLabel.textContent = "Custom Range";
                }
            } else {
                headingPeriodLabel.textContent = ` This ${label}`;
            }
        }

        const chips = document.querySelectorAll<HTMLElement>(".filter-chip");
        const rows = document.querySelectorAll<HTMLElement>(".transactionrow");
        const subLabel = document.querySelector<HTMLElement>(".table-heading-sub");

        chips.forEach((chip) => {
            chip.addEventListener("click", () => {
                chips.forEach((c) => c.classList.remove("active"));
                chip.classList.add("active");

                const filter = chip.dataset.filter;

                if (subLabel) {
                    subLabel.textContent =
                        filter === "all"
                            ? "Showing all employees"
                            : `Showing ${filter} employees`;
                }

                rows.forEach((row) => {
                    const status = row.dataset.status;
                    if (filter === "all" || status === filter) {
                        row.classList.remove("hidden");
                    } else {
                        row.classList.add("hidden");
                    }
                });
            });
        });

        function recalcNetPay() {
            const gross = parseFloat((document.getElementById('pay-gross') as HTMLInputElement)?.value.replace(/[₱,]/g, '') || '0');
            const bonus = parseFloat((document.getElementById('pay-bonus') as HTMLInputElement)?.value || '0');
            const overtime = parseFloat((document.getElementById('pay-overtime') as HTMLInputElement)?.value || '0');
            const deduction = parseFloat((document.getElementById('pay-deduction') as HTMLInputElement)?.value || '0');

            const net = gross + bonus + overtime - deduction;
            const netEl = document.getElementById('pay-netpay');
            if (netEl) netEl.textContent = formatPeso(net);
        }

        ['pay-bonus', 'pay-overtime', 'pay-deduction'].forEach((id) => {
            document.getElementById(id)?.addEventListener('input', recalcNetPay);
        });

        document.querySelectorAll<HTMLElement>('[data-modal]').forEach((trigger) => {
            trigger.addEventListener('click', () => {
                const modal = document.getElementById(trigger.dataset.modal!);
                if (!modal) return;

                if (modal.id === 'pay-employee-modal') {
                    const row = trigger.closest<HTMLElement>('.transactionrow');
                    if (row) {
                        const employee = row.dataset.employee || '';
                        const position = row.dataset.position || '';
                        const rate = parseFloat(row.dataset.rate || '0');
                        const remaining = parseFloat(row.dataset.remaining || '0');

                        const grossPay = remaining > 0 ? remaining : rate;
                        const shifts = remaining > 0 ? Math.round(remaining / rate) : 0;

                        const nameEl = document.getElementById('pay-employee-name');
                        const posEl = document.getElementById('pay-employee-position');
                        const paymentEl = document.getElementById('pay-employee-payment');
                        const periodEl = document.getElementById('pay-employee-period');
                        const shiftsEl = document.getElementById('pay-employee-shifts');
                        const rateEl = document.getElementById('pay-employee-rate');
                        const grossInput = document.getElementById('pay-gross') as HTMLInputElement;
                        const bonusInput = document.getElementById('pay-bonus') as HTMLInputElement;
                        const overtimeInput = document.getElementById('pay-overtime') as HTMLInputElement;
                        const deductionInput = document.getElementById('pay-deduction') as HTMLInputElement;

                        if (nameEl) nameEl.textContent = employee;
                        if (posEl) posEl.textContent = position;
                        if (paymentEl) paymentEl.textContent = formatPeso(grossPay);
                        if (periodEl) periodEl.textContent = "27/05/2026 - 27/05/2026";
                        if (shiftsEl) shiftsEl.textContent = String(shifts);
                        if (rateEl) rateEl.textContent = formatPeso(rate);

                        if (grossInput) grossInput.value = formatPeso(grossPay);
                        if (bonusInput) bonusInput.value = "0.00";
                        if (overtimeInput) overtimeInput.value = "0.00";
                        if (deductionInput) deductionInput.value = "0.00";

                        recalcNetPay();
                    }
                }

                modal.classList.add('open');
                modal.setAttribute('aria-hidden', 'false');
            });
        });

        document.querySelectorAll<HTMLElement>('.modal-overlay').forEach((modal) => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal(modal);
            });
            modal.querySelector('.modal-close')?.addEventListener('click', () => closeModal(modal));
            modal.querySelector('.btn-secondary')?.addEventListener('click', () => closeModal(modal));
        });

        document.querySelectorAll<HTMLElement>('.advanced-toggle').forEach((btn) => {
            btn.addEventListener('click', () => {
                const targetId = btn.id.replace('advanced-toggle', 'advanced-fields');
                const fields = document.getElementById(targetId);
                if (!fields) return;
                const isOpen = fields.classList.toggle('open');
                btn.classList.toggle('open', isOpen);
            });
        });

        // Period dropdown
        const periodDropdown = document.getElementById('period-dropdown');
        const periodTrigger = document.getElementById('period-trigger');
        const periodTriggerLabel = document.getElementById('period-trigger-label');
        const periodMenu = document.getElementById('period-menu');
        const periodOptions = document.querySelectorAll<HTMLElement>('.period-option');
        const customDateFields = document.getElementById('custom-date-fields');

        periodTrigger?.addEventListener('click', (e) => {
            e.stopPropagation();
            periodDropdown?.classList.toggle('open');
        });

        document.addEventListener('click', (e) => {
            if (periodDropdown && !periodDropdown.contains(e.target as Node)) {
                periodDropdown.classList.remove('open');
            }
        });

        periodOptions.forEach((option) => {
            option.addEventListener('click', () => {
                periodOptions.forEach((o) => o.classList.remove('active'));
                option.classList.add('active');

                const period = option.dataset.period || "";
                const label = option.textContent?.trim() || "";

                if (periodTriggerLabel) {
                    periodTriggerLabel.textContent =
                        period === "custom"
                            ? "Custom"
                            : ` This ${label}`;
                }

                updateOverviewHeading(period, label);

                if (period === 'custom') {
                    customDateFields?.classList.add('visible');
                } else {
                    customDateFields?.classList.remove('visible');
                }

                periodDropdown?.classList.remove('open');
            });
        });

        periodFrom?.addEventListener("change", () => {
            updateOverviewHeading("custom", "Custom");
        });

        periodTo?.addEventListener("change", () => {
            updateOverviewHeading("custom", "Custom");
        });

    });
</script>