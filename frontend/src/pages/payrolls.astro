        background: #f3f5f9;
    }

    .btn-primary--navy {
        padding: 12px;
        background: var(--primary-orange);
        color: #fff;
        border: none;
        border-radius: var(--radius-md);
        font-family: var(--general-text-font);
        font-size: var(--paragraph-text);
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s ease, transform 0.15s ease;
    }

    .btn-primary--navy:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    @media (max-width: 1500px) {
        .overviews {
            grid-template-columns: 1fr 1fr;
        }

        .overview-item {
            border-right: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.25);
            padding: var(--space-sm) var(--space-md);
        }

        .overview-item:nth-child(odd) {
            border-right: 1px solid rgba(255, 255, 255, 0.25);
        }

        .overview-item:nth-last-child(-n+2) {
            border-bottom: none;
        }
    }

    @media (max-width: 700px) {
        .payrolls-inner {
            gap: var(--space-md);
        }

        .heading-section {
            padding: var(--space-md);
            gap: var(--space-sm);
            border-radius: var(--radius-md);
        }

        .heading-title {
            font-size: 1.3rem;
        }

        .date-chip {
            padding: 5px 10px;
            font-size: 0.75rem;
            border-radius: var(--radius-sm);
        }

        .date-separator {
            font-size: 0.75rem;
        }

        .overviews {
            grid-template-columns: 1fr 1fr;
        }

        .overview-item {
            padding: var(--space-sm) var(--space-md);
        }

        .overview-label {
            font-size: 0.7rem;
            margin-bottom: 4px;
        }

        .overview-value {
            font-size: 1.6rem;
        }

        .transaction-headings {
            padding: var(--space-sm) var(--space-md);
            gap: var(--space-sm);
        }

        .table-heading-title {
            font-size: 0.85rem;
        }

        .table-heading-sub {
            font-size: 0.75rem;
        }

        .filter-chip {
            padding: 5px 10px;
            font-size: 0.7rem;
        }

        .payroll-labels,
        .transactionrow {
            grid-template-columns: 1fr 1fr 1fr;
            padding: var(--space-sm) var(--space-md);
        }

        .payroll-labels {
            font-size: 0.7rem;
        }

        .transactionrow {
            font-size: 0.75rem;
        }

        .payroll-labels p:nth-child(n+4),
        .transactionrow p:nth-child(n+4) {
            display: none;
        }
