---
const chartId = "dashboard-income-vs-outgoing";
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth() + 1;
---

<div class="chart-wrap" id={chartId} data-year={year} data-month={month}>
  <div class="chart-status" id={`${chartId}-status`}>Loading...</div>
  <canvas class="chart-canvas" id={`${chartId}-canvas`} style="display:none;"></canvas>
</div>

<script>
  const _chartId = "dashboard-income-vs-outgoing";

  async function _loadChart() {
    const canvas = document.getElementById(`${_chartId}-canvas`);
    const status = document.getElementById(`${_chartId}-status`);
    if (!canvas || !status) return;

    if (typeof Chart === "undefined") {
      const timeout = new Promise((_, reject) => setTimeout(() => reject(new Error("Chart.js CDN load timed out")), 8000));
      await Promise.race([
        new Promise((resolve, reject) => {
          const s = document.createElement("script");
          s.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js";
          s.onload = resolve;
          s.onerror = reject;
          document.head.appendChild(s);
        }),
        timeout,
      ]);
    }

    const BASE = "http://127.0.0.1:8000/api/analytics";
    const el = document.getElementById(_chartId);
    const year = parseInt(el.dataset.year);
    const month = parseInt(el.dataset.month);

    try {
      const res = await fetch(`${BASE}/charts/income-vs-expenses/?period=monthly&year=${year}&month=${month}`, { headers: { Accept: "application/json" } });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      const labels = Object.keys(data.income);
      const incomeVals = labels.map((k) => parseFloat(data.income[k]) || 0);
      const expenseVals = labels.map((k) => parseFloat(data.expenses[k]) || 0);

      if (labels.length === 0) {
        status.textContent = "No data for this month.";
        canvas.style.display = "none";
        status.style.display = "block";
        return;
      }

      status.style.display = "none";
      canvas.style.display = "block";

      if (canvas._chart) canvas._chart.destroy();

      canvas._chart = new Chart(canvas, {
        type: "line",
        data: {
          labels,
          datasets: [
            {
              label: "Income",
              data: incomeVals,
              borderColor: "#22c55e",
              backgroundColor: "rgba(34,197,94,0.08)",
              borderWidth: 2.5,
              pointRadius: 3.5,
              pointBackgroundColor: "#22c55e",
              pointBorderColor: "#fff",
              pointBorderWidth: 1.5,
              tension: 0.35,
              fill: true,
            },
            {
              label: "Expenses",
              data: expenseVals,
              borderColor: "#ef4444",
              backgroundColor: "rgba(239,68,68,0.08)",
              borderWidth: 2.5,
              pointRadius: 3.5,
              pointBackgroundColor: "#ef4444",
              pointBorderColor: "#fff",
              pointBorderWidth: 1.5,
              tension: 0.35,
              fill: true,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: { duration: 600 },
          plugins: {
            legend: {
              position: "top",
              align: "end",
              labels: {
                boxWidth: 12, boxHeight: 12, borderRadius: 2,
                font: { size: 11 }, padding: 16,
              },
            },
            tooltip: {
              callbacks: {
                label: (ctx) => ctx.dataset.label + ": ₱" + Number(ctx.parsed.y).toLocaleString("en-US", { minimumFractionDigits: 2 }),
              },
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                callback: (val) => {
                  if (val >= 1000000) return "₱" + (val / 1000000).toFixed(1) + "M";
                  if (val >= 1000) return "₱" + (val / 1000).toFixed(0) + "k";
                  return "₱" + val;
                },
                font: { size: 10 },
              },
              grid: { color: "rgba(0,0,0,0.06)" },
            },
            x: {
              ticks: { font: { size: 10 } },
              grid: { display: false },
            },
          },
        },
      });
    } catch (err) {
      status.textContent = "Error: " + err.message;
      canvas.style.display = "none";
      status.style.display = "block";
      console.error("DashboardIncomeVsOutgoing error:", err);
    }
  }

  function _init() {
    _loadChart().catch(err => {
      const status = document.getElementById(`${_chartId}-status`);
      if (status) status.textContent = "Error: " + err.message;
      console.error("DashboardIncomeVsOutgoing init error:", err);
    });
  }

  _init();
  document.addEventListener("astro:page-load", _init);
</script>

<style>
  .chart-wrap { width: 100%; height: 100%; position: relative; font-family: system-ui, sans-serif; }
  .chart-status { text-align: center; color: #9ca3af; padding: 1.5rem; font-size: 0.875rem; }
  .chart-canvas { width: 100% !important; height: 100% !important; max-height: 100%; }
</style>
