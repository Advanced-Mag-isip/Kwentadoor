---
const chartId = "dashboard-incoming-by-wallet";
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth() + 1;
---

<div class="chart-wrap" id={chartId} data-year={year} data-month={month}>
  <div class="chart-status" id={`${chartId}-status`}>Loading...</div>
  <canvas class="chart-canvas" id={`${chartId}-canvas`} style="display:none;"></canvas>
</div>

<script>
  const _chartId = "dashboard-incoming-by-wallet";
  const _chartState = window.__chartState__ || (window.__chartState__ = {});
  if (!_chartState[_chartId]) {
    _chartState[_chartId] = { initPromise: null, listenersAttached: false };
  }

  async function _ensureChartJs() {
    if (window.Chart) return;
    if (window.__chartJsLoading) return window.__chartJsLoading;
    window.__chartJsLoading = new Promise((resolve, reject) => {
      const s = document.createElement("script");
      s.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js";
      s.onload = resolve;
      s.onerror = () => reject(new Error("Chart.js CDN load failed"));
      document.head.appendChild(s);
    });
    return window.__chartJsLoading;
  }

  async function _loadChart() {
    const canvas = document.getElementById(`${_chartId}-canvas`);
    const status = document.getElementById(`${_chartId}-status`);
    if (!canvas || !status) return;

    await _ensureChartJs();

    const BASE = `${import.meta.env.PUBLIC_API_URL}/analytics`;
    const el = document.getElementById(_chartId);
    const year = parseInt(el.dataset.year);
    const month = parseInt(el.dataset.month);

    try {
      const res = await fetch(`${BASE}/charts/incoming-by-wallet/?year=${year}&month=${month}`, { headers: { Accept: "application/json" } });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      const entries = Object.entries(data).sort((a, b) => b[1] - a[1]);

      if (entries.length === 0) {
        status.textContent = "No incoming funds this month.";
        canvas.style.display = "none";
        status.style.display = "block";
        return;
      }

      const labels = entries.map(([name]) => name);
      const amounts = entries.map(([, amt]) => amt);

      status.style.display = "none";
      canvas.style.display = "block";

      if (canvas._chart) canvas._chart.destroy();

      canvas._chart = new Chart(canvas, {
        type: "bar",
        data: {
          labels,
          datasets: [{
            label: "Incoming (₱)",
            data: amounts,
            backgroundColor: "#1A2B4A",
            borderRadius: 3,
            barThickness: 32,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: { duration: 600 },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => "₱" + Number(ctx.parsed.y).toLocaleString("en-US", { minimumFractionDigits: 2 }),
              },
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                callback: (val) => {
                  if (val >= 1000000) return "₱" + (val / 1000000).toFixed(1) + "M";
                  if (val >= 1000) return "₱" + (val / 1000).toFixed(0) + "k";
                  return "₱" + val;
                },
                font: { size: 10 },
              },
              grid: { color: "rgba(0,0,0,0.06)" },
            },
            x: {
              ticks: { font: { size: 10 } },
              grid: { display: false },
            },
          },
        },
      });
    } catch (err) {
      status.textContent = "Error: " + err.message;
      canvas.style.display = "none";
      status.style.display = "block";
      console.error("DashboardIncomingByWallet error:", err);
    }
  }

  function _init() {
    if (_chartState[_chartId].initPromise) {
      return _chartState[_chartId].initPromise;
    }
    _chartState[_chartId].initPromise = _loadChart().catch(err => {
      _chartState[_chartId].initPromise = null;
      const status = document.getElementById(`${_chartId}-status`);
      if (status) status.textContent = "Error: " + err.message;
      console.error("DashboardIncomingByWallet init error:", err);
      throw err;
    });
    return _chartState[_chartId].initPromise;
  }

  _init();
  if (!_chartState[_chartId].listenersAttached) {
    _chartState[_chartId].listenersAttached = true;
    document.addEventListener("astro:page-load", _init);
  }
</script>

<style>
  .chart-wrap { width: 100%; height: 100%; position: relative; font-family: system-ui, sans-serif; }
  .chart-status { text-align: center; color: #9ca3af; padding: 1.5rem; font-size: 0.875rem; }
  .chart-canvas { width: 100% !important; height: 100% !important; max-height: 100%; }
</style>
