<div id="filter-header">
    <span id="filter-summary-text">No filters selected</span>
    
    <div id="filters">
        <form>
            <select id="filter-period-type" class="filter" name="period_type">
                <option value="" disabled>Filter by</option>
                <option value="year" selected>Filter by Year</option>
                <option value="quarter">Filter by Quarter</option>
                <option value="month">Filter by Month</option>
            </select>
            <select id="filter-year" class="filter" name="year">
                <option value="" disabled selected>Select Year</option>
            </select>
            <select id="filter-period-value" class="filter" name="period_value">
                <option value="" disabled selected></option>
            </select>
        </form>
        <button id="apply-filters" type="button" class="custom-button">Apply</button>
        <button id="export-button" type="button" class="custom-button">Export</button>
    </div>
</div>

<script>
    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const BASE = "http://127.0.0.1:8000/api/analytics";

    let _periodData = null;

    async function _fetchPeriods() {
        if (_periodData) return _periodData;
        try {
            const res = await fetch(`${BASE}/available-periods/`, { headers: { Accept: "application/json" } });
            if (res.ok) {
                const data = await res.json();
                if (data && data.years && data.years.length > 0) {
                    _periodData = data;
                    return _periodData;
                }
            }
        } catch (e) {
            console.error("available-periods fetch failed:", e);
        }
        _periodData = { years: [new Date().getFullYear()], months: {} };
        return _periodData;
    }

    async function _initFilters() {
        const typeSel = document.getElementById('filter-period-type');
        const yearSel = document.getElementById('filter-year');
        const valueSel = document.getElementById('filter-period-value');
        const summaryText = document.getElementById('filter-summary-text');
        if (!typeSel || !yearSel || !valueSel || !summaryText) return;

        const data = await _fetchPeriods();
        const availYears = data.years;
        const availMonthsByYear = data.months;

        yearSel.innerHTML = '<option value="" disabled selected>Select Year</option>';
        for (const y of availYears) {
            const opt = document.createElement('option');
            opt.value = y;
            opt.textContent = y;
            yearSel.appendChild(opt);
        }
        if (availYears.length > 0) yearSel.value = availYears[availYears.length - 1];

        function monthsForYear(y) {
            return availMonthsByYear[String(y)] || [];
        }

        function quartersForYear(y) {
            const ms = monthsForYear(y);
            const qs = new Set();
            for (const m of ms) qs.add(Math.ceil(m / 3));
            return [...qs].sort((a, b) => a - b);
        }

        function populatePeriodValue() {
            const type = typeSel.value;
            const y = parseInt(yearSel.value);
            valueSel.innerHTML = '<option value="" disabled selected></option>';
            if (!type || !y || isNaN(y)) return;

            if (type === 'year') {
                const opt = document.createElement('option');
                opt.value = y;
                opt.textContent = y;
                opt.selected = true;
                valueSel.appendChild(opt);
            } else if (type === 'quarter') {
                const qs = quartersForYear(y);
                for (const q of qs) {
                    const opt = document.createElement('option');
                    opt.value = 'Q' + q;
                    opt.textContent = 'Q' + q;
                    valueSel.appendChild(opt);
                }
                if (valueSel.options.length > 0) valueSel.selectedIndex = valueSel.options.length - 1;
            } else {
                const ms = monthsForYear(y);
                for (const m of ms) {
                    const opt = document.createElement('option');
                    opt.value = m;
                    opt.textContent = MONTHS[m - 1];
                    valueSel.appendChild(opt);
                }
                if (valueSel.options.length > 0) valueSel.selectedIndex = valueSel.options.length - 1;
            }
        }

        function getFilters() {
            const type = typeSel.value;
            const y = parseInt(yearSel.value);
            const rawVal = valueSel.value;
            if (!type || !y || isNaN(y)) return null;
            if (type === 'year') return { period: 'yearly', year: y, month: null };
            if (!rawVal) return null;
            if (type === 'month') return { period: 'monthly', year: y, month: parseInt(rawVal) };
            if (type === 'quarter') {
                const q = parseInt(rawVal.replace('Q', ''));
                return { period: 'quarterly', year: y, month: (q - 1) * 3 + 1 };
            }
            return null;
        }

        function updateSummary() {
            const f = getFilters();
            if (!f) { summaryText.textContent = 'No filters selected'; return; }
            let text = '';
            if (f.period === 'monthly' && f.month) {
                text = MONTHS[f.month - 1] + ' ' + f.year;
            } else if (f.period === 'quarterly' && f.month) {
                const q = Math.floor((f.month - 1) / 3) + 1;
                text = 'Q' + q + ' ' + f.year;
            } else {
                text = 'All ' + f.year;
            }
            summaryText.textContent = 'Showing Results for ' + text.toUpperCase();
        }

        function applyFilters() {
            const f = getFilters();
            window.__chartFilters = f;
            updateSummary();
            document.dispatchEvent(new CustomEvent('chart-update', { detail: f }));
        }

        function togglePeriodValue() {
            valueSel.style.display = typeSel.value === 'year' ? 'none' : '';
        }

        typeSel.addEventListener('change', populatePeriodValue);
        typeSel.addEventListener('change', togglePeriodValue);
        yearSel.addEventListener('change', populatePeriodValue);
        valueSel.addEventListener('change', () => {});

        const applyBtn = document.getElementById('apply-filters');
        if (applyBtn) applyBtn.addEventListener('click', applyFilters);

        const exportBtn = document.getElementById('export-button');
        if (exportBtn) exportBtn.addEventListener('click', () => {});

        const form = document.querySelector('#filters form');
        if (form) form.addEventListener('submit', (e) => e.preventDefault());

        populatePeriodValue();
        togglePeriodValue();
        applyFilters();
    }

    _initFilters();
    document.addEventListener('astro:page-load', _initFilters);
</script>

<style>
