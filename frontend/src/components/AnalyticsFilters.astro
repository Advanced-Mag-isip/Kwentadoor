<div id="filter-header">
    <span id="filter-summary-text">No filters selected</span>

    <div id="filters">
        <form>
            <div class="period-dropdown" id="period-type-dropdown">
                <button type="button" class="period-trigger" id="period-type-trigger" aria-haspopup="listbox" aria-expanded="false">
                    <span id="period-type-trigger-label">Filter by Year</span>
                    <span class="period-chevron">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </span>
                </button>
                <div class="period-menu" id="period-type-menu" role="listbox">
                    <button type="button" class="period-option active" data-value="year" role="option" aria-selected="true">Year</button>
                    <button type="button" class="period-option" data-value="quarter" role="option" aria-selected="false">Quarter</button>
                    <button type="button" class="period-option" data-value="month" role="option" aria-selected="false">Month</button>
                </div>
            </div>

            <select id="filter-period-type" class="filter filter-hidden-native" name="period_type" tabindex="-1" aria-hidden="true">
                <option value="" disabled>Filter by</option>
                <option value="year" selected>Filter by Year</option>
                <option value="quarter">Filter by Quarter</option>
                <option value="month">Filter by Month</option>
            </select>

            <div class="period-dropdown" id="year-dropdown">
                <button type="button" class="period-trigger" id="year-trigger" aria-haspopup="listbox" aria-expanded="false">
                    <span id="year-trigger-label">Select Year</span>
                    <span class="period-chevron">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </span>
                </button>
                <div class="period-menu" id="year-menu" role="listbox"></div>
            </div>
            <select id="filter-year" class="filter filter-hidden-native" name="year" tabindex="-1" aria-hidden="true">
                <option value="" disabled selected>Select Year</option>
            </select>

            <div class="period-dropdown" id="period-value-dropdown">
                <button type="button" class="period-trigger" id="period-value-trigger" aria-haspopup="listbox" aria-expanded="false">
                    <span id="period-value-trigger-label"></span>
                    <span class="period-chevron">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </span>
                </button>
                <div class="period-menu" id="period-value-menu" role="listbox"></div>
            </div>
            <select id="filter-period-value" class="filter filter-hidden-native" name="period_value" tabindex="-1" aria-hidden="true">
                <option value="" disabled selected></option>
            </select>
        </form>
        <button id="apply-filters" type="button" class="custom-button custom-button--primary">Apply</button>
        <div class="export-dropdown-container">
            <button id="export-button" type="button" class="custom-button custom-button--ghost">Export</button>
            <div id="export-menu" class="export-menu">
                <button type="button" class="export-option" data-format="xlsx">Excel (.xlsx)</button>
                <button type="button" class="export-option" data-format="pdf">PDF Report</button>
            </div>
        </div>
    </div>
</div>

<script>
    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const BASE = "http://127.0.0.1:8000/api/analytics";

    let _periodData = null;

    async function _fetchPeriods() {
        if (_periodData) return _periodData;
        try {
            const res = await fetch(`${BASE}/available-periods/`, { headers: { Accept: "application/json" } });
            if (res.ok) {
                const data = await res.json();
                if (data && data.years && data.years.length > 0) {
                    _periodData = data;
                    return _periodData;
                }
            }
        } catch (e) {
            console.error("available-periods fetch failed:", e);
        }
        _periodData = { years: [new Date().getFullYear()], months: {} };
        return _periodData;
    }

    function _closeAllDropdowns(except) {
        document.querySelectorAll('.period-dropdown.open').forEach((d) => {
            if (d !== except) {
                d.classList.remove('open');
                const t = d.querySelector('.period-trigger');
                if (t) t.setAttribute('aria-expanded', 'false');
            }
        });
    }

    function _initDropdownToggle(dropdownEl) {
        if (!dropdownEl || dropdownEl.dataset.dropdownInitialized === 'true') return;
        const trigger = dropdownEl.querySelector('.period-trigger');
        trigger.addEventListener('click', (e) => {
            e.stopPropagation();
            _closeAllDropdowns(dropdownEl);
            const isOpen = dropdownEl.classList.toggle('open');
            trigger.setAttribute('aria-expanded', String(isOpen));
        });
        dropdownEl.dataset.dropdownInitialized = 'true';
    }

    if (!window.__filterDropdownGlobalClickBound) {
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.period-dropdown')) _closeAllDropdowns(null);
        });
        window.__filterDropdownGlobalClickBound = true;
    }

    function _renderDropdownFromSelect(selectEl, dropdownEl, labelEl) {
        const menuEl = dropdownEl.querySelector('.period-menu');
        menuEl.innerHTML = '';
        [...selectEl.options].filter(o => !o.disabled).forEach((o) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'period-option' + (o.value === selectEl.value ? ' active' : '');
            btn.setAttribute('role', 'option');
            btn.setAttribute('aria-selected', o.value === selectEl.value ? 'true' : 'false');
            btn.textContent = o.textContent;
            btn.addEventListener('click', () => {
                selectEl.value = o.value;
                selectEl.dispatchEvent(new Event('change', { bubbles: true }));
                menuEl.querySelectorAll('.period-option').forEach((c) => {
                    c.classList.remove('active');
                    c.setAttribute('aria-selected', 'false');
                });
                btn.classList.add('active');
                btn.setAttribute('aria-selected', 'true');
                labelEl.textContent = o.textContent;
                dropdownEl.classList.remove('open');
                dropdownEl.querySelector('.period-trigger').setAttribute('aria-expanded', 'false');
            });
            menuEl.appendChild(btn);
        });
        const selected = selectEl.options[selectEl.selectedIndex];
        labelEl.textContent = selected ? selected.textContent : '';
        _initDropdownToggle(dropdownEl);
    }

    async function _initFilters() {
        const typeSel = document.getElementById('filter-period-type');
        const yearSel = document.getElementById('filter-year');
        const valueSel = document.getElementById('filter-period-value');
        const summaryText = document.getElementById('filter-summary-text');
        
        if (!typeSel || !yearSel || !valueSel || !summaryText) return;
        
        // FIX 1: Set the initialization flag so events don't double-bind
        if (typeSel.dataset.analyticsFiltersInitialized === 'true') return;
        typeSel.dataset.analyticsFiltersInitialized = 'true';

        // FIX 2: Move export button logic ABOVE the await call
        const exportBtn = document.getElementById('export-button');
        const exportMenu = document.getElementById('export-menu');
        const exportOptions = document.querySelectorAll('.export-option');

        if (exportBtn && exportMenu) {
            exportBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                exportMenu.classList.toggle('show');
            });

            exportOptions.forEach(button => {
                button.addEventListener('click', (e) => {
                    exportMenu.classList.remove('show'); 
                    const f = getFilters();
                    if (!f) {
                        alert("Please apply a filter first.");
                        return;
                    }

                    const format = e.target.getAttribute('data-format'); 
                    let url = `${BASE}/export/?period=${f.period}&year=${f.year}&export_format=${format}`;
                    if (f.month) {
                        url += `&month=${f.month}`;
                    }
                    window.open(url, '_blank');
                });
            });

            document.addEventListener('click', (e) => {
                if (!exportBtn.contains(e.target) && !exportMenu.contains(e.target)) {
                    exportMenu.classList.remove('show');
                }
            });
        }

        const yearDropdown = document.getElementById('year-dropdown');
        const yearLabel = document.getElementById('year-trigger-label');
        const valueDropdown = document.getElementById('period-value-dropdown');
        const valueLabel = document.getElementById('period-value-trigger-label');

        // Note: The await happens down here now, safely AFTER UI listeners are attached
        const data = await _fetchPeriods();
        const availYears = data.years;
        const availMonthsByYear = data.months;
        

        yearSel.innerHTML = '<option value="" disabled selected>Select Year</option>';
        for (const y of availYears) {
            const opt = document.createElement('option');
            opt.value = y;
            opt.textContent = y;
            yearSel.appendChild(opt);
        }
        if (availYears.length > 0) yearSel.value = availYears[availYears.length - 1];
        _renderDropdownFromSelect(yearSel, yearDropdown, yearLabel);

        function monthsForYear(y) {
            return availMonthsByYear[String(y)] || [];
        }

        function quartersForYear(y) {
            const ms = monthsForYear(y);
            const qs = new Set();
            for (const m of ms) qs.add(Math.ceil(m / 3));
            return [...qs].sort((a, b) => a - b);
        }

        function populatePeriodValue() {
            const type = typeSel.value;
            const y = parseInt(yearSel.value);
            valueSel.innerHTML = '<option value="" disabled selected></option>';
            if (type && y && !isNaN(y)) {
                if (type === 'year') {
                    const opt = document.createElement('option');
                    opt.value = y;
                    opt.textContent = y;
                    opt.selected = true;
                    valueSel.appendChild(opt);
                } else if (type === 'quarter') {
                    const qs = quartersForYear(y);
                    for (const q of qs) {
                        const opt = document.createElement('option');
                        opt.value = 'Q' + q;
                        opt.textContent = 'Q' + q;
                        valueSel.appendChild(opt);
                    }
                    if (valueSel.options.length > 0) valueSel.selectedIndex = valueSel.options.length - 1;
                } else {
                    const ms = monthsForYear(y);
                    for (const m of ms) {
                        const opt = document.createElement('option');
                        opt.value = m;
                        opt.textContent = MONTHS[m - 1];
                        valueSel.appendChild(opt);
                    }
                    if (valueSel.options.length > 0) valueSel.selectedIndex = valueSel.options.length - 1;
                }
            }
            _renderDropdownFromSelect(valueSel, valueDropdown, valueLabel);
        }

        function getFilters() {
            const type = typeSel.value;
            const y = parseInt(yearSel.value);
            const rawVal = valueSel.value;
            if (!type || !y || isNaN(y)) return null;
            if (type === 'year') return { period: 'yearly', year: y, month: null };
            if (!rawVal) return null;
            if (type === 'month') return { period: 'monthly', year: y, month: parseInt(rawVal) };
            if (type === 'quarter') {
                const q = parseInt(rawVal.replace('Q', ''));
                return { period: 'quarterly', year: y, month: (q - 1) * 3 + 1 };
            }
            return null;
        }

        function updateSummary() {
            const f = getFilters();
            if (!f) { summaryText.textContent = 'No filters selected'; return; }
            let text = '';
            if (f.period === 'monthly' && f.month) {
                text = MONTHS[f.month - 1] + ' ' + f.year;
            } else if (f.period === 'quarterly' && f.month) {
                const q = Math.floor((f.month - 1) / 3) + 1;
                text = 'Q' + q + ' ' + f.year;
            } else {
                text = 'All ' + f.year;
            }
            summaryText.textContent = 'Showing Results for ' + text.toUpperCase();
        }

        function applyFilters() {
            const f = getFilters();
            if (!f) return;
            window.__chartFilters = f;
            updateSummary();
            document.dispatchEvent(new CustomEvent('chart-update', { detail: f }));
        }

        function togglePeriodValue() {
            if (valueDropdown) valueDropdown.style.display = typeSel.value === 'year' ? 'none' : '';
        }

        typeSel.addEventListener('change', populatePeriodValue);
        typeSel.addEventListener('change', togglePeriodValue);
        yearSel.addEventListener('change', populatePeriodValue);

        const applyBtn = document.getElementById('apply-filters');
        if (applyBtn) applyBtn.addEventListener('click', applyFilters);

        togglePeriodValue();   
        populatePeriodValue(); 
        applyFilters();       
    }

    function _initPeriodTypeDropdown() {
        const typeSel = document.getElementById('filter-period-type');
        const dropdown = document.getElementById('period-type-dropdown');
        const trigger = document.getElementById('period-type-trigger');
        const triggerLabel = document.getElementById('period-type-trigger-label');
        const menu = document.getElementById('period-type-menu');
        if (!typeSel || !dropdown || !trigger || !menu) return;

        _initDropdownToggle(dropdown);

        if (dropdown.dataset.optionsInitialized === 'true') return;
        
        const options = menu.querySelectorAll('.period-option');
        options.forEach((opt) => {
            opt.addEventListener('click', () => {
                options.forEach((o) => {
                    o.classList.remove('active');
                    o.setAttribute('aria-selected', 'false');
                });
                opt.classList.add('active');
                opt.setAttribute('aria-selected', 'true');

                triggerLabel.textContent = 'Filter by ' + opt.textContent.trim();
                typeSel.value = opt.dataset.value;
                typeSel.dispatchEvent(new Event('change', { bubbles: true }));

                dropdown.classList.remove('open');
                trigger.setAttribute('aria-expanded', 'false');
            });
        });

        dropdown.dataset.optionsInitialized = 'true';
    }

    // FIX 3: Rely solely on Astro View Transitions lifecycle events
    document.addEventListener('astro:page-load', _initFilters);
    document.addEventListener('astro:page-load', _initPeriodTypeDropdown);
</script>

<style is:global>
    #filter-header {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: var(--space-md);
        width: 100%;
        border-radius: var(--radius-lg);
        box-sizing: border-box;
        padding: var(--space-md) var(--space-lg);
        background-image: var(--orange-gradient);
        font-family: var(--display-headings-font);
        font-size: var(--title-text);
        font-weight: bold;
        color: var(--white);
        box-shadow: var(--default-shadow);
        margin-bottom: 20px;
    }

    #filters, form {
        display: flex;
        flex-direction: row;
        align-items: center;
        flex-wrap: wrap;
        gap: var(--space-sm);
    }

    .period-dropdown {
        position: relative;
    }

    .period-trigger {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.15);
        border: none;
        border-radius: var(--radius-md);
        padding: 12px 16px;
        font-family: var(--general-text-font);
        font-size: 16px;
        font-weight: normal;
        color: var(--white);
        cursor: pointer;
        white-space: nowrap;
        transition: background-color 150ms ease;
    }

    .period-trigger:hover {
        background: rgba(255, 255, 255, 0.24);
    }

    .period-chevron {
        display: flex;
        align-items: center;
        width: 14px;
        height: 14px;
        transition: transform 0.2s ease;
    }

    .period-chevron svg {
        width: 14px;
        height: 14px;
        stroke: var(--white);
    }

    .period-dropdown.open .period-chevron {
        transform: rotate(180deg);
    }

    .period-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        background: var(--white);
        border-radius: var(--radius-md);
        box-shadow: var(--default-shadow);
        padding: 6px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 140px;
        max-height: 260px;
        overflow-y: auto;
        z-index: 50;
        opacity: 0;
        transform: translateY(-6px);
        pointer-events: none;
        transition: opacity 0.15s ease, transform 0.15s ease;
    }

    .period-dropdown.open .period-menu {
        opacity: 1;
        transform: translateY(0);
        pointer-events: all;
    }

    .period-option {
        background: none;
        border: none;
        text-align: left;
        padding: 8px 10px;
        border-radius: 6px;
        font-family: var(--general-text-font);
        font-size: 15px;
        color: var(--primary-navyblue);
        cursor: pointer;
        transition: background-color 150ms ease;
    }

    .period-option:hover {
        background: #f3f5f9;
    }

    .period-option.active {
        background: var(--primary-orange);
        color: var(--white);
    }

    .filter-hidden-native {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    /* ---- Buttons ---- */
    .custom-button {
        appearance: none;
        outline: none;
        padding: 12px 24px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid var(--white);
        font-family: var(--display-headings-font);
        font-weight: bold;
        font-size: 16px;
        color: var(--white);
        cursor: pointer;
        transition: transform 150ms ease, opacity 150ms ease;
    }

    .custom-button--primary {
        background-image: var(--navyblue-gradient);
    }

    .custom-button--ghost {
        background: rgba(255, 255, 255, 0.1);
    }

    .custom-button:hover {
        transform: translateY(-2px);
        opacity: 0.92;
    }

    .custom-button:active {
        transform: translateY(0);
    }
    
    .export-dropdown-container {
        position: relative;
        display: inline-block;
    }

    .export-menu {
        display: none; 
        position: absolute;
        top: 100%; 
        right: 0; 
        margin-top: 8px;
        background-color: white;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        z-index: 50;
        min-width: 140px;
        overflow: hidden;
    }

    .export-menu.show {
        display: block;
    }

    .export-option {
        display: block;
        width: 100%;
        padding: 10px 15px;
        border: none;
        background: transparent;
        text-align: left;
        font-size: 14px;
        cursor: pointer;
        color: #334155;
        transition: background-color 0.2s ease;
    }

    .export-option:hover {
        background-color: #f1f5f9;
    }

    @media (max-width: 700px) {
        #filter-header {
            padding: var(--space-md);
            font-size: 1.05rem;
            gap: var(--space-sm);
        }

        #filters {
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-sm);
        }

        #filters form {
            display: contents;
        }

        #period-value-dropdown {
            grid-column: 1 / -1;
        }

        .period-trigger {
            width: 100%;
            justify-content: space-between;
            padding: 10px 14px;
            font-size: 14px;
        }

        .custom-button {
            width: 100%;
            padding: 10px 16px;
            font-size: 14px;
        }

        .period-menu {
            left: 0;
            right: 0;
            min-width: unset;
        }
    }
</style>