---
import '../styles/global.css';
import cashUpcon from "../assets/cash-up-icon.svg?raw";
---

<dialog id="addExpenseModal" class="modal-dialog">
  <div class="modal-content">
    
    <div class="modal-header">
      <div class="header-title">
        <span class="header-icon"><Fragment set:html={cashUpcon} /></span>
        <h2>Spend Funds</h2>
      </div>


    <button type="button" id="close-modal-icon" class="close-btn">&times;</button>
    </div>
    
    <div class="modal-body">
      <div class="input-group">
        <label for="fund-amount-input">FUND AMOUNT</label>
        <div class="input-wrapper">
          <span class="input-icon font-peso">₱</span>
          <input type="number" id="fund-amount-input" name="amount" placeholder="Enter Amount"/>
        </div>
      </div>

      <div class="form-row">
        <div class="input-group">
          <label for="spend-category-input">SPEND CATEGORY</label>
          <div class="select-wrapper">
            <span class="input-icon"></span>
            <select id="spend-category-input" name="category">
              <option value="" disabled selected>Select Category</option>
              <option value="food">Food & Beverage</option>
              <option value="transport">Transportation</option>
              <option value="utilities">Utilities</option>
            </select>
          </div>
        </div>

        <div class="input-group">
          <label for="source-wallet-input">SOURCE WALLET</label>
          <div class="select-wrapper">
            <span class="input-icon"></span>
            <select id="source-wallet-input" name="wallet">
              <option value="" disabled selected>Select Wallet</option>
              <option value="cash">Cash</option>
              <option value="bank">Bank Account</option>
            </select>
          </div>
        </div>
      </div>

      <details class="advanced-section">
        <summary>Advanced</summary>
        
        <div class="advanced-content">
          <div class="input-group">
            <label for="note-input">NOTE</label>
            <textarea id="note-input" name="note" placeholder="Add a note about this transaction..."></textarea>
          </div>

          <div class="input-group">
            <label for="counter-party-input">COUNTER PARTY</label>
            <div class="input-wrapper">
              <span class="input-icon"></span>
              <input type="text" id="counter-party-input" name="counterparty" placeholder="Enter counter party name..." />
            </div>
          </div>

          <div class="form-row">
            <div class="input-group">
              <label for="date-input">DATE</label>
              <input type="date" id="date-input" name="date" value="2026-06-30" />
            </div>

            <div class="input-group">
              <label>ATTACHMENT</label>
              <label class="file-upload-wrapper" for="attachment-input">
                <span class="placeholder-text">Select files</span>
                <span class="paperclip-icon">📎</span>
              </label>
              <input type="file" id="attachment-input" name="attachment" accept="image/*" style="display: none;" />
            </div>
          </div>
        </div>
      </details>

      <div class="modal-actions">
        <button type="button" class="btn btn-orange">Save and Add Another</button>
        <div class="action-row">
            <button type="button" id="cancel-modal-btn" class="btn btn-outline w-100" style="flex: 1;">Cancel</button>
            <button type="submit" class="btn btn-navy" style="flex: 1;">Add Fund</button>
        </div>
      </div>
      
      <slot />
    </div>
  </div>
</dialog>

<script>
  const modal = document.getElementById('addExpenseModal');
  const closeIcon = document.getElementById('close-modal-icon');
  const cancelBtn = document.getElementById('cancel-modal-btn');

  // Only attach listener if the open button exists on the current page

  // Only attach listeners if the modal and close buttons exist
  if (modal && closeIcon) {
    closeIcon.addEventListener('click', () => {
      modal.close();
    });
  }

  if (modal && cancelBtn) {
    cancelBtn.addEventListener('click', () => {
      modal.close();
    });
  }
</script>


<style>
  * {
    box-sizing: border-box;
  }

  :root {
    --primary-orange-hover: #e05a16;
    --primary-navy: var(--primary-navyblue);
    --text-dark: #B1B1B1;
    --text-muted: #B1B1B1;
    --border-color: #7F7F7F;
    --bg-white: #ffffff;
  }
.modal-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0; 
    padding: 0;
    border: none;
    border-radius: 25px;
    background-color: var(--white);
    width: 470px;
    min-height: 754px; 
    max-width: 100%;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }


  .modal-dialog[open] {
    display: flex;
    flex-direction: column;
  }

  .modal-dialog::backdrop {
    background-color: rgba(26, 43, 74, 0.7);
    backdrop-filter: blur(3px);
  }

  .modal-content {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    background-image: var(--orange-gradient);
    color: var(--white);
    font-family: var(--display-headings-font);
  }

  .header-title {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    fill: white;
  }

  .modal-header h2 {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: white;
    line-height: 1;
    opacity: 0.8;
  }

  .close-btn:hover {
    opacity: 1;
  }

  .modal-body {
    padding: 24px;
    font-family: var(--general-text-font);
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-row {
    display: flex;
    gap: 16px;
    width: 100%;
  }

  .form-row .input-group {
    flex: 1;
  }

  /* Typography & Labels */
  label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    color: var(--primary-navyblue);
    margin-bottom: 6px;
    letter-spacing: 0.5px;
  }

  /* Form Inputs */
  input[type="text"],
  input[type="number"],
  input[type="date"],
  select,
  textarea {
    width: 100%;
    height: 44px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0 16px;
    font-size: 14px;
    color: var(--text-dark);
    outline: none;
    font-family: inherit;
    transition: border-color 0.2s ease;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--primary-orange);
  }

  input::placeholder, textarea::placeholder {
    color: var(--text-muted);
  }

  textarea {
    height: 80px;
    padding: 12px 16px;
    resize: none;
  }

  /* Input Wrappers (Icons) */
  .input-wrapper, .select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-wrapper input, .select-wrapper select {
    padding-left: 40px; /* Space for icon */
  }

  .input-icon {
    position: absolute;
    left: 14px;
    color: var(--text-muted);
    font-size: 16px;
    pointer-events: none;
  }

  .font-peso {
    font-weight: 600;
    color: var(--primary-navy);
  }

  select {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2394a3b8%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E");
    background-repeat: no-repeat;
    background-position: right 14px top 50%;
    background-size: 10px auto;
  }

  /* File Upload Styling */
  .file-upload-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 44px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0 16px;
    cursor: pointer;
    margin: 0;
  }

  .file-upload-wrapper .placeholder-text {
    color: var(--text-muted);
    font-size: 14px;
    font-weight: normal;
  }

  .file-upload-wrapper .paperclip-icon {
    color: var(--primary-navy);
    font-size: 16px;
  }

  /* Advanced Collapsible Section */
  .advanced-section {
    border-top: 1px solid var(--border-color);
    margin-top: 8px;
    padding-top: 16px;
  }

  .advanced-section summary {
    font-size: 14px;
    font-weight: 600;
    color: var(--primary-navy);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .advanced-section summary::after {
    content: "▼";
    font-size: 10px;
    color: var(--primary-navy);
    transition: transform 0.2s ease;
  }

  .advanced-section[open] summary::after {
    transform: rotate(180deg);
  }

  .advanced-section summary::-webkit-details-marker {
    display: none;
  }

  .advanced-content {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Buttons */
  .modal-actions {
    margin-top: auto;
    padding-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .action-row {
    display: flex;
    gap: 12px;
    width: 100%;
  }

  .w-100 {
    width: 100%;
  }

  .btn {
    height: 48px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.2s ease;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .btn-orange {
    background-color: var(--primary-orange);
    color: white;
    width: 100%;
  }

  .btn-orange:hover {
    background-color: var(--primary-orange-hover);
  }

  .btn-outline {
    background-color: white;
    border: 1px solid var(--border-color);
    color: var(--text-muted);
  }

  .btn-outline:hover {
    border-color: var(--text-dark);
    color: var(--text-dark);
  }

  .btn-navy {
    background-color: var(--primary-navy);
    color: white;
  }

  .btn-navy:hover {
    background-color: #111d33;
  }
</style>