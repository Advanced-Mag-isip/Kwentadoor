---
import homeIcon from '../assets/home-icon.svg?raw'; 
import walletIcon from '../assets/wallet-icon.svg?raw'; 
import analyticsIcon from '../assets/analytics-icon.svg?raw';
import payrollIcon from '../assets/payroll-icon.svg?raw'; 
import companyLogo from '../assets/Trabahadoor-logo-white.svg?raw'; 
import logoutLogo from '../assets/log-out-icon.svg?raw'; 
import '../styles/global.css';
const currentPath = Astro.url.pathname;
---
<nav id = "main-navigation">
    <div id = "nav-safe-area">
        <div id = "sidebar-up">
            <div id = "logo-area">
                <a href = "/" id = "company-logo">
                <Fragment set:html={companyLogo} height = 20 width = 20/>
                </a>
                <h1><span style = "color: var(--white);">Kwenta</span><span style= "color: var(--primary-orange);">Door</span></h1>
            </div> 

            <div id = "nav-links">

                
                <div id = "navigation-group" class = "nav-group">
                    <label for = "navigation-group">NAVIGATION</label>
                   <a href = "">
                        <div>
                            <Fragment set:html={homeIcon} />
                            <span>Dashboard</span>
                        </div>
                   </a>
                </div>

               
                <div id = "financials-group" class = "nav-group">
                     <label for = "financials-group">FINANCIALS</label>
                   <a href = "">
                        <div>
                            <Fragment set:html={walletIcon} />
                            <span>Wallet</span>
                        </div>
                   </a>

                   <a href = "">
                        <div>
                            <Fragment set:html={analyticsIcon} />
                            <span>Analytics</span>
                        </div>
                   </a>
                </div>

                
                <div id = "team-group" class = "nav-group">
                    <label for = "team-group">TEAM</label>

                    <a href = "/">
                        <div>
                            <Fragment set:html={payrollIcon} />
                            <span>Payroll</span>
                        </div>
                    </a>
                   
                </div>
            </div>
        </div>
        
        <div id = "sidebar-down" class = "nav-group">
            <a href = "/">
                <div>
                    <Fragment set:html={logoutLogo} />
                    <span>Logout</span>
                </div>
            </a>
        </div>
    </div>
</nav>

<style> 
    label,#sidebar-down{
        font-size: 13px;
    }

    #nav-safe-area {
      display: flex;
      flex-direction: column;
      height: 100%;
  }

    #nav-links  :global(svg), #sidebar-down :global(svg){
        width: 15px;
        height: auto; 
    }
    #company-logo :global(svg) {
        width: 40px;
        height: auto;
    }

    #main-navigation{
        background-color: var(--primary-navyblue);
        width: 230px;
        height: 100vh;
    }

    #logo-area{
        font-size: 10px;
        font-family: var(--display-headings-font);
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        gap: 3px; 
        padding: 30px 0px;
        border-bottom: 2px solid var(--white);
        font-weight: bold;
        
    }

    #nav-links{
        color: var(--white); 
        font-family: var(--general-text-font);
        font-size: 15px;
    }

    #nav-links div,  #sidebar-down div{
        padding: 10px 15px;
    }

    .nav-group div:hover{
        background-color: var(--primary-orange);
    }


    a{
        text-decoration: none;
        color: var(--white); 
    }

    #sidebar-down{
        margin-top: auto;
        border-top: 2px solid var(--white);
        padding: 20px 10px;
    }


    .nav-group div{
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: flex-start; 
        gap: 15px;
        border-radius: 8px;
        color: var(--white); 
        margin: 8px 0px;
        font-family: var(--general-text-font);
        background-color: var(--light-navyblue);
        box-shadow: var(--default-shadow);

     }

    
</style>